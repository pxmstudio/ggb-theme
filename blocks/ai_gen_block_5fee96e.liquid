{% doc %}
  @prompt
    Create a slider for Featured Brands section that displays brand logos in a carousel format with navigation controls

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .brand-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding: 0 40px;
    margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
  }

  .brand-slider-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 30px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .brand-slider-track-{{ ai_gen_id }} {
    display: flex;
    overflow: hidden;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }

  .brand-slider-slide-{{ ai_gen_id }} {
    flex: 0 0 calc(100% / {{ block.settings.brands_per_view }});
    min-width: calc(100% / {{ block.settings.brands_per_view }});
    padding: 0 {{ block.settings.slide_padding }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-slider-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-slider-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: opacity 0.3s;
  }

  .brand-slider-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-slider-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-height: {{ block.settings.logo_height }}px;
    object-fit: contain;
    background-color: {{ block.settings.placeholder_bg_color }};
    border-radius: 4px;
  }

  .brand-slider-nav-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_text_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  }

  .brand-slider-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
  }

  .brand-slider-prev-{{ ai_gen_id }} {
    left: 0;
  }

  .brand-slider-next-{{ ai_gen_id }} {
    right: 0;
  }

  .brand-slider-nav-icon-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
  }

  .brand-slider-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .brand-slider-link-{{ ai_gen_id }}:hover .brand-slider-image-{{ ai_gen_id }} {
    opacity: {{ block.settings.hover_opacity | divided_by: 100.0 }};
  }

  @media screen and (max-width: 749px) {
    .brand-slider-slide-{{ ai_gen_id }} {
      flex: 0 0 calc(100% / {{ block.settings.brands_per_view_mobile }});
      min-width: calc(100% / {{ block.settings.brands_per_view_mobile }});
    }
    
    .brand-slider-{{ ai_gen_id }} {
      padding: 0 30px;
    }
    
    .brand-slider-nav-button-{{ ai_gen_id }} {
      width: 30px;
      height: 30px;
    }
  }
{% endstyle %}

<brand-slider-{{ ai_gen_id }} 
  class="brand-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="brand-slider-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <button 
    class="brand-slider-nav-button-{{ ai_gen_id }} brand-slider-prev-{{ ai_gen_id }}" 
    aria-label="Previous brands"
  >
    <svg class="brand-slider-nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="brand-slider-track-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% assign logo_key = 'brand_logo_' | append: i %}
      {% assign link_key = 'brand_link_' | append: i %}
      {% assign logo = block.settings[logo_key] %}
      {% assign link = block.settings[link_key] %}

      {% if logo != blank or forloop.index <= block.settings.placeholder_count %}
        <div class="brand-slider-slide-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="brand-slider-link-{{ ai_gen_id }}" {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}>
          {% endif %}
          
          <div class="brand-slider-image-wrapper-{{ ai_gen_id }}">
            {% if logo != blank %}
              <img 
                src="{{ logo | img_url: 'medium' }}" 
                alt="{{ logo.alt | escape }}" 
                loading="lazy"
                class="brand-slider-image-{{ ai_gen_id }}"
                width="{{ logo.width }}"
                height="{{ logo.height }}"
              >
            {% else %}
              <div class="brand-slider-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <button 
    class="brand-slider-nav-button-{{ ai_gen_id }} brand-slider-next-{{ ai_gen_id }}" 
    aria-label="Next brands"
  >
    <svg class="brand-slider-nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</brand-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.brand-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.brand-slider-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.brand-slider-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.brand-slider-next-{{ ai_gen_id }}');
        this.slidesPerView = {{ block.settings.brands_per_view }};
        this.currentIndex = 0;
        this.slideCount = this.slides.length;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        if (this.slides.length <= this.slidesPerView) {
          this.prevButton.style.display = 'none';
          this.nextButton.style.display = 'none';
          return;
        }

        this.setupEventListeners();
        this.updateButtonStates();
        this.setupAutoplay();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.slidePrev());
        this.nextButton.addEventListener('click', () => this.slideNext());
        
        // Pause autoplay on hover
        this.addEventListener('mouseenter', () => this.pauseAutoplay());
        this.addEventListener('mouseleave', () => this.setupAutoplay());
        
        // Handle responsive changes
        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.updateButtonStates();
        });
      }
      
      updateSlidesPerView() {
        if (window.innerWidth <= 749) {
          this.slidesPerView = {{ block.settings.brands_per_view_mobile }};
        } else {
          this.slidesPerView = {{ block.settings.brands_per_view }};
        }
      }

      slidePrev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlidePosition();
        }
      }

      slideNext() {
        if (this.currentIndex < this.slideCount - this.slidesPerView) {
          this.currentIndex++;
          this.updateSlidePosition();
        }
      }

      updateSlidePosition() {
        const slideWidth = this.slides[0].offsetWidth;
        this.track.scrollLeft = this.currentIndex * slideWidth;
        this.updateButtonStates();
      }

      updateButtonStates() {
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= this.slideCount - this.slidesPerView;
        
        this.prevButton.style.opacity = this.prevButton.disabled ? '0.5' : '1';
        this.nextButton.style.opacity = this.nextButton.disabled ? '0.5' : '1';
      }
      
      setupAutoplay() {
        if (!{{ block.settings.enable_autoplay }}) return;
        
        this.pauseAutoplay();
        this.autoplayInterval = setInterval(() => {
          if (this.currentIndex >= this.slideCount - this.slidesPerView) {
            this.currentIndex = 0;
          } else {
            this.currentIndex++;
          }
          this.updateSlidePosition();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }
      
      pauseAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.pauseAutoplay();
      }
    }

    customElements.define('brand-slider-{{ ai_gen_id }}', BrandSlider{{ ai_gen_id }});
  })();
</script>

