{
  "name": "ggb-theme",
  "author": "PixelMakers",
  "license": "ISC",
  "description": "GoGoBaby Shopify Theme",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsc --watch && vite build --watch && npx tailwindcss -i ./src/styles.css -o ./assets/styles.css --watch",
    "build": "tsc && vite build && npx tailwindcss -i ./src/styles.css -o ./assets/styles.css --watch",
    "preview": "vite preview",
    "shopify": "shopify theme dev --store gogobaby-ro",
    "tw-minify": "npx tailwindcss -i ./src/styles.css -o ./assets/styles.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "autoprefixer": "^10.4.20",
    "eslint-plugin-tailwindcss": "^3.17.5",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vite-plugin-ts": "^1.3.2-1"
  },
  "dependencies": {
    "gsap": "^3.12.5"
  }
}
