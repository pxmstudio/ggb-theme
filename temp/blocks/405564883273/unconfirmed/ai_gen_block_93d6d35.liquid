{% doc %}
  @prompt
    A magazine-style editorial layout

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.text_font.family }}, serif;
    font-weight: {{ block.settings.text_font.weight }};
  }

  .ai-editorial__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;}

  .ai-editorial__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: 20px;
  }

  .ai-editorial__headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, serif;
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.2;
    margin: 0 0 10px;color: {{ block.settings.headline_color }};
  }

  .ai-editorial__subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, serif;
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.3;
    margin: 0;
    color: {{ block.settings.subheading_color }};
  }

  .ai-editorial__author-{{ ai_gen_id }} {
    margin-top: 15px;
    font-style: italic;
    font-size: 16px;
  }

  .ai-editorial__featured-image-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-editorial__featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-editorial__featured-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial__featured-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.7;
  }

  .ai-editorial__caption-{{ ai_gen_id }} {
    font-size: 14px;
    margin-top: 8px;
    font-style: italic;
    text-align: center;
  }

  .ai-editorial__content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .ai-editorial__body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_text_size }}px;
    line-height: 1.6;
  }

  .ai-editorial__body-{{ ai_gen_id }} p {
    margin-bottom: 1.2em;
  }

  .ai-editorial__body-{{ ai_gen_id }} p:first-child::first-letter {
    {% if block.settings.enable_drop_cap %}
      font-family: {{ block.settings.heading_font.family }}, serif;
      font-weight: {{ block.settings.heading_font.weight }};
      float: left;
      font-size: 4em;
      line-height: 0.8;
      padding-right: 8px;
      color: {{ block.settings.headline_color }};
    {% endif %}
  }

  .ai-editorial__pull-quote-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, serif;
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.4;
    padding: 20px 40px;
    position: relative;
    color: {{ block.settings.quote_color }};
    text-align: center;
    border-left: 4px solid {{ block.settings.quote_color }};
    margin: 30px 0;font-style: italic;
  }

  .ai-editorial__pull-quote-{{ ai_gen_id }}::before {
    content: """;
    font-size: 4em;
    position: absolute;
    left: 10px;
    top: -20px;
    opacity: 0.2;
    color: {{ block.settings.quote_color }};
  }

  .ai-editorial__pull-quote-{{ ai_gen_id }}::after {
    content: """;
    font-size: 4em;
    position: absolute;
    right: 10px;
    bottom: -70px;
    opacity: 0.2;
    color: {{ block.settings.quote_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-editorial__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }

    .ai-editorial__header-{{ ai_gen_id }} {
      grid-column: 1 / -1;
    }

    .ai-editorial__featured-image-{{ ai_gen_id }} {
      {% if block.settings.layout == 'image_left' %}
        grid-column: 1 / 2;{% elsif block.settings.layout == 'image_right' %}
        grid-column: 2 / 3;
      {% else %}
        grid-column: 1 / -1;
      {% endif %}
    }

    .ai-editorial__content-{{ ai_gen_id }} {
      {% if block.settings.layout == 'image_left' %}
        grid-column: 2 / 3;
      {% elsif block.settings.layout == 'image_right' %}
        grid-column: 1 / 2;
      {% else %}
        grid-column: 1 / -1;
      {% endif %}
    }

    {% if block.settings.layout == 'image_top' %}
      .ai-editorial__container-{{ ai_gen_id }} {
        grid-template-columns: 1fr;
      }{% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-editorial__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-editorial__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-editorial__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-editorial__pull-quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_size | times: 0.8 }}px;
      padding: 15px 25px;
    }
  }
{% endstyle %}

<div class="ai-editorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial__container-{{ ai_gen_id }}">
    <header class="ai-editorial__header-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-editorial__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
      {% endif %}
      
      {% if block.settings.subheading != blank %}
        <h3 class="ai-editorial__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</h3>
      {% endif %}
      
      {% if block.settings.author != blank %}
        <div class="ai-editorial__author-{{ ai_gen_id }}">{{ block.settings.author }}</div>
      {% endif %}
    </header><div class="ai-editorial__featured-image-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1500 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}">
      {% else %}
        <div class="ai-editorial__featured-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
      {% if block.settings.caption != blank %}
        <div class="ai-editorial__caption-{{ ai_gen_id }}">{{ block.settings.caption }}</div>
      {% endif %}
    </div>
    
    <div class="ai-editorial__content-{{ ai_gen_id }}">
      <div class="ai-editorial__body-{{ ai_gen_id }}">
        {{ block.settings.body_text }}
      </div>
      
      {% if block.settings.pull_quote != blank %}
        <blockquote class="ai-editorial__pull-quote-{{ ai_gen_id }}">
          {{ block.settings.pull_quote }}
        </blockquote>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Editorial Layout",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout style",
      "options": [
        {
          "value": "image_left",
          "label": "Image left"
        },
        {
          "value": "image_right",
          "label": "Image right"
        },
        {
          "value": "image_top",
          "label": "Image top"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "The Art of Design"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Exploring the intersection of form and function"
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author",
      "default": "By Jane Smith"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1/1",
          "label": "1:1 (Square)"
        },
        {
          "value": "3/2",
          "label": "3:2"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        }
      ],
      "default": "3/2"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Image caption",
      "default": "Photo by Jane Smith"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p><p>Aenean faucibus nibh et justo cursus id rutrum lorem imperdiet. Nunc ut sem vitae risus tristique posuere. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia Curae; Fusce id purus.</p><p>Utenim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.</p>"
    },
    {
      "type": "textarea",
      "id": "pull_quote",
      "label": "Pull quote",
      "default": "Design is not just what it looks like and feels like. Design is how it works."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "serif"
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Body font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "headline_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Headline size",
      "default": 42
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 16,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_text_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "quote_size",
      "min": 18,
      "max": 42,
      "step": 1,
      "unit": "px",
      "label": "Pull quote size",
      "default": 28
    },
    {
      "type": "checkbox",
      "id": "enable_drop_cap",
      "label": "Enable drop cap",
      "default": true
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Pull quote color",
      "default": "#000f9f"
    }
  ],
  "presets": [
    {
      "name": "Editorial Layout"
    }
  ]
}
{% endschema %}