{% doc %}
  @prompt
    Create a collections slider section that displays only products with discounts greater than 30%. The section should automatically filter products where the compare-at price is set and the discount percentage ((compare_at_price - price) / compare_at_price * 100) is greater than 30%. Show product image, title, original price (crossed out), sale price, and the discount percentage badge. The slider should be responsive and match the existing theme style.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-discount-slider-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-discount-slider__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-discount-slider__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 30px;
  }

  .ai-discount-slider__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 10px;
    font-weight: 700;
  }

  .ai-discount-slider__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-discount-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-discount-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.product_gap }}px;
    transition: transform 0.4s ease;
    padding: 10px 0;
  }

  .ai-discount-slider__product-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.products_per_row | minus: 1 | times: block.settings.product_gap }}px) / {{ block.settings.products_per_row }});
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-discount-slider__product-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-discount-slider__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-discount-slider__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-discount-slider__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 10px;
    right: 10px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 700;
    z-index: 2;
  }

  .ai-discount-slider__content-{{ ai_gen_id }} {
    padding: 15px;
  }

  .ai-discount-slider__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 10px;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-decoration: none;
  }

  .ai-discount-slider__product-title-{{ ai_gen_id }}:hover {
    color: {{ block.settings.product_title_hover_color }};
  }

  .ai-discount-slider__prices-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .ai-discount-slider__original-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.original_price_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-discount-slider__sale-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | plus: 2 }}px;
    color: {{ block.settings.sale_price_color }};
    font-weight: 700;
  }

  .ai-discount-slider__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_background }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background-color 0.3s ease, opacity 0.3s ease;
    opacity: 0.9;
  }

  .ai-discount-slider__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_background }};
    opacity: 1;
  }

  .ai-discount-slider__nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-discount-slider__nav--prev-{{ ai_gen_id }} {
    left: -20px;
  }

  .ai-discount-slider__nav--next-{{ ai_gen_id }} {
    right: -20px;
  }

  .ai-discount-slider__nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-discount-slider__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-discount-slider__product-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.products_per_row_tablet | minus: 1 | times: block.settings.product_gap }}px) / {{ block.settings.products_per_row_tablet }});
    }
  }

  @media screen and (max-width: 749px) {
    .ai-discount-slider__product-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - 1 * {{ block.settings.product_gap }}px) / 2);
    }

    .ai-discount-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-discount-slider__nav-{{ ai_gen_id }} {
      width: 35px;
      height: 35px;
    }

    .ai-discount-slider__nav--prev-{{ ai_gen_id }} {
      left: 0;
    }

    .ai-discount-slider__nav--next-{{ ai_gen_id }} {
      right: 0;
    }
  }
{% endstyle %}

<discount-products-slider-{{ ai_gen_id }} class="ai-discount-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-discount-slider__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-discount-slider__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-discount-slider__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-discount-slider__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% liquid
      assign discount_products = blank
      assign discount_products_array = ''
      assign min_discount = block.settings.minimum_discount_percent

      if block.settings.collection != blank
        for product in block.settings.collection.products limit: 50
          if product.compare_at_price_max > product.price
            assign discount_percent = product.compare_at_price_max | minus: product.price | times: 100.0 | divided_by: product.compare_at_price_max | floor
            if discount_percent >= min_discount
              assign discount_products_array = discount_products_array | append: product.id | append: '|' | append: discount_percent | append: ','
            endif
          endif
        endfor
      endif

      assign products_data = discount_products_array | split: ','
    %}

    {% if products_data.size > 0 %}
      <div class="ai-discount-slider__wrapper-{{ ai_gen_id }}">
        <button
          class="ai-discount-slider__nav-{{ ai_gen_id }} ai-discount-slider__nav--prev-{{ ai_gen_id }}"
          aria-label="Previous products"
          data-nav="prev"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div class="ai-discount-slider__track-{{ ai_gen_id }}" data-track>
          {% for product_data in products_data %}
            {% if product_data != blank %}
              {% assign data_parts = product_data | split: '|' %}
              {% assign product_id = data_parts[0] %}
              {% assign discount_percent = data_parts[1] %}
              {% assign product = all_products[product_id] %}

              {% if product != blank %}
                <div class="ai-discount-slider__product-{{ ai_gen_id }}">
                  <a href="{{ product.url }}" class="ai-discount-slider__image-wrapper-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        class="ai-discount-slider__image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="600"
                        height="600"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag }}
                    {% endif %}
                    <div class="ai-discount-slider__badge-{{ ai_gen_id }}">
                      -{{ discount_percent }}%
                    </div>
                  </a>
                  <div class="ai-discount-slider__content-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" class="ai-discount-slider__product-title-{{ ai_gen_id }}">
                      {{ product.title }}
                    </a>
                    <div class="ai-discount-slider__prices-{{ ai_gen_id }}">
                      <span class="ai-discount-slider__original-price-{{ ai_gen_id }}">
                        {{ product.compare_at_price_max | money }}
                      </span>
                      <span class="ai-discount-slider__sale-price-{{ ai_gen_id }}">
                        {{ product.price | money }}
                      </span>
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>

        <button
          class="ai-discount-slider__nav-{{ ai_gen_id }} ai-discount-slider__nav--next-{{ ai_gen_id }}"
          aria-label="Next products"
          data-nav="next"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% else %}
      <div class="ai-discount-slider__empty-{{ ai_gen_id }}">
        {% if block.settings.collection == blank %}
          Selectați o colecție pentru a afișa produsele cu reduceri.
        {% else %}
          Nu există produse cu reduceri mai mari de {{ block.settings.minimum_discount_percent }}% în această colecție.
        {% endif %}
      </div>
    {% endif %}
  </div>
</discount-products-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class DiscountProductsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.track = this.querySelector('[data-track]');
        this.prevButton = this.querySelector('[data-nav="prev"]');
        this.nextButton = this.querySelector('[data-nav="next"]');
        this.products = this.track ? Array.from(this.track.children) : [];
        this.productsPerView = {{ block.settings.products_per_row }};
        this.productsPerViewTablet = {{ block.settings.products_per_row_tablet }};
        this.productsPerViewMobile = 2;
      }

      connectedCallback() {
        if (!this.track || this.products.length === 0) return;

        this.updateProductsPerView();
        this.updateButtons();
        this.setupEventListeners();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.slide('prev'));
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.slide('next'));
        }

        window.addEventListener('resize', () => {
          this.updateProductsPerView();
          this.updateSlidePosition();
          this.updateButtons();
        });

        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          isDragging = true;
        });

        this.track.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
        });

        this.track.addEventListener('touchend', () => {
          if (!isDragging) return;
          const diff = startX - currentX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.slide('next');
            } else {
              this.slide('prev');
            }
          }
          isDragging = false;
        });
      }

      updateProductsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.productsPerView = this.productsPerViewMobile;
        } else if (width <= 989) {
          this.productsPerView = this.productsPerViewTablet;
        } else {
          this.productsPerView = {{ block.settings.products_per_row }};
        }
      }

      slide(direction) {
        const maxIndex = Math.max(0, this.products.length - this.productsPerView);

        if (direction === 'next') {
          this.currentIndex = Math.min(this.currentIndex + 1, maxIndex);
        } else {
          this.currentIndex = Math.max(this.currentIndex - 1, 0);
        }

        this.updateSlidePosition();
        this.updateButtons();
      }

      updateSlidePosition() {
        if (!this.track || this.products.length === 0) return;

        const productWidth = this.products[0].offsetWidth;
        const gap = {{ block.settings.product_gap }};
        const offset = this.currentIndex * (productWidth + gap);

        this.track.style.transform = `translateX(-${offset}px)`;
      }

      updateButtons() {
        if (!this.prevButton || !this.nextButton) return;

        const maxIndex = Math.max(0, this.products.length - this.productsPerView);

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }
    }

    customElements.define('discount-products-slider-{{ ai_gen_id }}', DiscountProductsSlider{{ ai_gen_id }});
  })();
</script>

