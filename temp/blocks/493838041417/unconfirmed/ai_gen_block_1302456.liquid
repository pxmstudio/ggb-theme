{% doc %}
  @prompt
    Adaugă un bloc de cod HTML custom în tema Shopify, care să permită inserarea de conținut HTML personalizat într-o secțiune a paginii.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-html-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-custom-html-content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-custom-html-empty-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    border: 2px dashed #cccccc;
    border-radius: 8px;
    padding: 40px 20px;
    text-align: center;
    color: #666666;
  }

  .ai-custom-html-empty-icon-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    margin: 0 auto 16px;
    opacity: 0.5;
  }

  .ai-custom-html-empty-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-custom-html-empty-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
    color: #333333;
  }

  .ai-custom-html-empty-text-{{ ai_gen_id }} {
    font-size: 14px;
    margin: 0;
  }
{% endstyle %}

<div class="ai-custom-html-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.custom_html != blank %}
    <div class="ai-custom-html-content-{{ ai_gen_id }}">
      {{ block.settings.custom_html }}
    </div>
  {% else %}
    <div class="ai-custom-html-empty-{{ ai_gen_id }}">
      <div class="ai-custom-html-empty-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
      </div>
      <h3 class="ai-custom-html-empty-title-{{ ai_gen_id }}">Conținut HTML personalizat</h3>
      <p class="ai-custom-html-empty-text-{{ ai_gen_id }}">Adaugă codul HTML în setările blocului</p>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "HTML personalizat",
  "settings": [
    {
      "type": "html",
      "id": "custom_html",
      "label": "Cod HTML"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Lățime desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "HTML personalizat"
    }
  ]
}
{% endschema %}
