<div class="relative {{ class }} hidden">
  <div id="search-container-{{ id }}" class="search-container">
    <input
      type="text"
      id="{{ id }}"
      name="q"
      placeholder="{{ placeholder }}"
      class="h-12 py-3 pl-6 pr-16 rounded-md border border-border-primary w-full"
      value="{{ search.terms | escape }}"
      form="filter-form"
    >
    <button
      type="submit"
      form="filter-form"
      id="search-btn-{{ id }}"
      class="absolute right-6 top-0 h-full flex items-center justify-center"
    >
      {% render 'icon-search', width: 24, height: 24, class: 'text-text-primary' %}
    </button>
  </div>
</div>

