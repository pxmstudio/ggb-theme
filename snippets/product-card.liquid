{% assign on_sale = false %}
{% if product.compare_at_price > product.price %}
  {% assign on_sale = true %}
{% endif %}

{% assign is_new = false %}
{% if product.tags contains 'noutati' or product.collections contains collections.noutati %}
  {% assign is_new = true %}
{% endif %}

{% comment %} Check if product is out of stock based on inventory quantity {% endcomment %}
{% assign is_sold_out = false %}
{% if product.selected_or_first_available_variant.inventory_quantity <= 0 %}
  {% assign is_sold_out = true %}
{% endif %}

<a
  href="{{ product.url }}"
  class="w-full h-full group relative"
  pxm-product="item"
  data-price="{{ product.price }}"
  data-compare-at="{{ product.compare_at_price_max }}"
  data-discount="{{ product.compare_at_price_max | minus: product.price | times: 100.0 | divided_by: product.compare_at_price_max | round }}"
>
  <div class="w-full aspect-square relative rounded-2xl overflow-hidden border border-border-primary">
    <img
      src="{{ product.featured_image | image_url: height: 300 }}"
      width="auto"
      height="300"
      class="absolute top-0 bottom-0 left-0 right-0 object-cover object-center w-full h-full group-hover:scale-110 global-transition {% if is_sold_out %}grayscale-[70%] brightness-95 group-hover:grayscale-[50%] group-hover:scale-[1.02]{% endif %}"
      pxm-product="image"
    >
    {% if product.compare_at_price > product.price %}
      <span
        class="absolute top-0 left-0 bg-error-red text-white px-2 py-1 rounded-br-2xl text-sm font-medium"
        pxm-product="discount"
      >
        -
        {{
          product.compare_at_price
          | minus: product.price
          | times: 100.0
          | divided_by: product.compare_at_price
          | round
        -}}
        %
      </span>
    {% endif %}
    {% if is_sold_out %}
      <span
        class="absolute top-0 right-0 bg-neutral-darker text-white px-3 py-1.5 rounded-bl-2xl text-xs font-semibold uppercase tracking-wide z-10"
        pxm-product="sold-out"
      >
        Stoc epuizat
      </span>
    {% endif %}
    {% if is_new %}
      <span
        class="absolute bottom-0 left-0 bg-[#54BFC7] text-white px-2 py-1 rounded-tr-2xl text-sm font-medium z-10">
        Noutati
      </span>
    {% endif %}
  </div>
  <div class="pt-4">
    <h3 class="text-text-primary lg:text-lg font-semibold leading-normal line-clamp-3 mb-2" pxm-product="title">
      {{ product.title }}
    </h3>
    <div class="flex items-center gap-4">
      <p class="text-text-secondary lg:text-lg font-semibold line-through" pxm-product="compare-price">
        {{ product.compare_at_price | money_without_trailing_zeros }}
      </p>
      <p
        class="{% if on_sale %}text-error-red{% else %}text-text-primary{% endif %} font-semibold lg:text-lg"
        pxm-product="price"
      >
        {{ product.price | money_without_trailing_zeros }}
      </p>
    </div>
    {% assign _compare_at = product.compare_at_price %}
    {% assign _price = product.price %}
    {% if _compare_at > _price and _compare_at > 0 and is_sold_out == false %}
      {% assign _savings = _compare_at | minus: _price %}
      {% assign _discount_percent = _savings | times: 100.0 | divided_by: _compare_at | round %}
      {% if _discount_percent >= 30 %}
        <img
          src="https://cdn.shopify.com/s/files/1/0431/6663/0052/files/star.png?v=1762239054"
          width="80"
          height="80"
          class="card-star"
        >
      {% endif %}
    {% endif %}
  </div>
</a>

<style>
  .card-star {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 10;
  }
  @media (max-width: 640px) {
    .card-star {
      width: 60px;
      height: 60px;
    }
  }

  .vtl-pr-review-stars-snippet-container.Vtl-ProductReviewsStars__Wrapper.Vtl-ProductReviewsStars__Wrapper {
  display: none !important;
}
</style>
