<a href="{{ article.url }}" class="block group">
  {% if article.image %}
    <div class="w-full aspect-video rounded-lg custom-gog-container overflow-hidden border border-transparent group-hover:border-border-secondary global-transition">
      <img
        src="{{ article.image.src | image_url: width: 600 }}"
        width="413"
        height="240"
        alt="{{ article.image.alt }}"
        class="w-full h-full object-cover object-center"
      >
    </div>
  {% endif %}
  <div class="pt-3">
    <div class="flex flex-col gog-my-container gap-3 mb-3 lg:mb-6">
      <h3 class="heading-h5 text-text-primary">{{ article.title }}</h3>
      <p class="text-text-primary lg:text-lg">{{ article.content | strip_html | truncate: 100 }}</p>
    </div>
    <div class="inline-flex items-center gap-3">
      <p class="lg:text-lg font-semibold text-text-primary">Citește mai mult</p>
      {% render 'icon-arrow-right',
        width: 24,
        height: 24,
        class: 'w-5 h-5 lg:w-6 lg:h-6global-transition group-hover:translate-x-1'
      %}
    </div>
  </div>
</a>
