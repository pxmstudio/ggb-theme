<div class="grid grid-cols-1 gap-4" pxm-product="image-gallery">
  <div class="order-2 flex gap-3 overflow-x-auto pb-2">
    {% for image in product.images %}
      <button
        data-active="{{ forloop.first }}"
        class="w-20 h-20 relative border data-[active=true]:border-border-secondary border-border-primary rounded-[0.375rem] overflow-hidden flex-shrink-0"
        data-gallery-item
        data-index="{{ forloop.index0 }}"
      >
        <img
          src="{{ image | image_url: width: 160 }}"
          alt="{{ product.title }}"
          width="{{ image.width }}"
          height="{{ image.height }}"
          class="absolute top-0 bottom-0 left-0 right-0 w-full h-full object-center object-cover pointer-events-none"
        >
      </button>
    {% endfor %}
  </div>

  <img
    src="{{ product.featured_image | image_url: width: 1000 }}"
    alt="{{ product.title }}"
    width="{{ product.featured_image.width }}"
    height="{{ product.featured_image.height }}"
    class="order-1 border border-border-primary rounded-2xl w-full max-w-full object-contain cursor-pointer"
    data-gallery-item
    data-index="0"
  >
</div>

{% render 'product-gallery-modal', product: product %}
