<section>
  <div class="global-padding pt-5 pb-10 lg:py-16">
    <div class="container-large">
      <div class="max-w-3xl mx-auto">
        <div class="mb-6 lg:mb-16 flex flex-col lg:items-center gap-3">
          <h1 class="heading-h1 text-text-primary">{{ section.settings.title }}</h1>
          <p class="lg:text-xl leading-normal text-text-secondary">{{ section.settings.description }}</p>
        </div>

        <div class="flex flex-col gap-4" pxm-faqs="container">
          {% for item in shop.metaobjects.faqs.values %}
            <div
              class="p-4 lg:p-8 rounded-2xl border border-border-primary data-[visible='true']:border-border-secondary global-transition"
              data-visible="false"
              pxm-faqs="item"
            >
              <button class="flex items-center justify-between gap-4 w-full" pxm-faqs="item-header">
                <h3 class="text-lg lg:text-xl font-semibold leading-normal text-text-primary text-left">
                  {{ item.question.value }}
                </h3>
                <div pxm-faqs="item-icon">
                  {% render 'icon-chevron-down', width: '32', height: '32' %}
                </div>
              </button>
              <div class="pt-4 lg:pt-8 opacity-0 hidden" pxm-faqs="item-content">
                <p class="lg:text-lg leading-normal text-text-secondary">{{ item.answer.value }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQs",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Întrebări frecvente"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Cele mai des întâlnite întrebări și răspunsuri."
    }
  ],
  "blocks": []
}
{% endschema %}
