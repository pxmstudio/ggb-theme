<div
  class="
    h-20 lg:h-20
    w-full z-100 mb-[-2rem]
  "
>
  <header
    class="header-promotii bg-promotii fixed top-0 left-1/2 transform -translate-x-1/2 w-full m-0 mx-auto z-50"
    data-template="{{ template.suffix }}"
  >
    <div class="global-padding ptb-2">
      <div class="container-large">
        <div class="header-promotii_wrapper w-full flex justify-between items-center lg:gap-8 gap-2">

          {% if template.name == 'index' %}
            <h1 class="relative z-100">
              <span class="sr-only">GoGoBaby</span>
          {% endif %}

          <a
            style="z-index: 100;"
            href="/"
            class="global-transition flex justify-center bg-brand-turquoise border-none rounded-full px-3 lg:px-6 py-1.5 lg:py-3 relative z-100 h-10 lg:h-16 w-auto"
          >
            {% render 'icon-logo' %}
          </a>

          {% if template.name == 'index' %}
            </h1>
          {% endif %}

          <!-- Text promoțional -->
          <p class="promo-summer-text flex-1 text-center text-white font-semibold leading-tight" style="font-size: 24px;">
            Profită de reducerile de vară!
          </p>

          <!-- Buton configurabil -->
          <div class="button-bf-container gog-but">
            {% render 'button-bf',
              type: 'link',
              hierarchy: 'primary',
              href: section.settings.button_link | default: '/',
              text: section.settings.button_text | default: 'Acasa'
            %}
          </div>

          <!-- Navigație desktop -->
          <div class="hidden lg:block relative" pxm-nav="menu">
            <nav class="flex lg:flex-row flex-col bradius-50 pt-52 px-28 lg:pt-0 lg:px-0 lg:justify-end items-center gap-8 lg:gap-6 fixed lg:static top-0 left-0 right-0 bottom-0 z-40 h-screen lg:h-auto bg-bg-primary w-full lg:opacity-100">
              <div class="flex items-center gap-2 lg:justify-end">
                <div class="flex items-center gap-2 lg:gap-3 bg-yellow">
                  <div class="hidden lg:block">
                    {% render 'nav-acc-btn', path: '/cart', icon: 'cart' %}
                  </div>
                </div>
              </div>
            </nav>

            {% render 'mobile-categories' %}
          </div>

          <!-- Coș pe mobil -->
          <div class="flex items-center gap-4 lg:hidden">
            <div class="z-50">
              {% render 'nav-acc-btn', path: '/cart', icon: 'cart' %}
            </div>
          </div>

        </div>
      </div>
    </div>

    <img
      src="https://cdn.shopify.com/s/files/1/0431/6663/0052/files/blue-line.svg?v=1765355976"
      alt=""
      class="w-full h-8 object-cover object-left absolute bottom-[-2rem] left-0"
      width="1440"
      height="32"
      style="object-position: left;"
    >
  </header>
</div>

<style>
  .header-black-friday_wrapper {
    padding-top: 1.5rem;
  }

  .bg-promotii {
    background-color: #33a3de;
  }

  .promo-summer-text {
    padding: 0 0.5rem;
  }

  .button-bf-container {
    margin-left: auto;
  }

  .button-bf {
    padding-right: 0.9rem !important;
    padding-left: 0.5rem !important;
    padding-top: 0.25rem !important;
    padding-bottom: 0.25rem !important;
    font-size: 0.8rem !important;
  }

  .bradius-50 {
    border-radius: 50%;
  }

  @media (max-width: 1024px) {
    .promo-summer-text {
      font-size: 0.85rem;
      line-height: 1.15;
      padding: 0 0.25rem;
    }

    .button-bf {
      padding-right: 0.5rem !important;
      padding-left: 0.25rem !important;
      padding-top: 0.25rem !important;
      padding-bottom: 0.25rem !important;
      font-size: 0.75rem !important;
    }
  }

  @media (max-width: 420px) {
    .promo-summer-text {
      font-size: 0.7rem;
      line-height: 1.1;
      padding: 0 0.15rem;
    }

    .button-bf-icon {
      display: none;
    }

    .button-bf {
      padding-right: 0.4rem !important;
      padding-left: 0.4rem !important;
      font-size: 0.7rem !important;
    }
  }
</style>

{% schema %}
{
  "name": "Header Promotii",
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Acasa"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "Header Promotii"
    }
  ]
}
{% endschema %}