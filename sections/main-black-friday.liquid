<section class="position-relative ">
  <div class="bf-hero-background max-w-full"></div>
  <div class="bf-hero-background-2 max-w-full"></div>

  <div class=" bf-hero-section container-large z-index-40 position-relative global-padding">
    <div class="text-center lg:py-16 py-8">
      <h1 class="bf-hero-title">{{ section.settings.hero_title | default: 'Spooky Deals' }}</h1>
      <div class="bf-hero-subtitle lg:heading-h5 heading-h6 font-semibold">
        {{ section.settings.subtitle_before | default: 'Bucură-te de oferte speciale, de până la' }}
        <span class="bf-hero-discount">{{ section.settings.subtitle_highlight | default: '60%' }}</span>
        {{ section.settings.subtitle_after | default: 'reducere!' }}
      </div>
    </div>
    <img
      src="{% if section.settings.image_left != blank %}{{ section.settings.image_left | image_url: width: 260 }}{% else %}https://cdn.shopify.com/s/files/1/0431/6663/0052/files/bg-image-2.png?v=1761919728{% endif %}"
      alt="Black Friday"
      class="bf-hero-image bf-hero-image--left"
      width="260"
      height="260"
    >
    <img
      src="{% if section.settings.image_right != blank %}{{ section.settings.image_right | image_url: width: 260 }}{% else %}https://cdn.shopify.com/s/files/1/0431/6663/0052/files/bg-image-2.png?v=1761919728{% endif %}"
      alt="Black Friday"
      class="bf-hero-image bf-hero-image--right"
      width="260"
      height="260"
    >
  </div>
  <div class="bf-hero-image-wrapper">
    <img
      src="{% if section.settings.image_figure != blank %}{{ section.settings.image_figure | image_url: width: 300 }}{% else %}https://cdn.shopify.com/s/files/1/0431/6663/0052/files/bf-image.png?v=1761919728{% endif %}"
      alt="Black Friday"
      class="bf-hero-figure z-index-10"
      width="300"
      height="200"
    >
  </div>
  <div class="bf-hero-line-wrapper">
    <img
      src="{% if section.settings.image_line != blank %}{{ section.settings.image_line | image_url: width: 1100 }}{% else %}https://cdn.shopify.com/s/files/1/0431/6663/0052/files/bg-line.png?v=1761919727{% endif %}"
      alt="Black Friday"
      class="bf-hero-line"
      width="1100"
      height="100"
    >
  </div>
</section>

<style>
    .bf-hero-title {
      font-family: 'CCPassThePort Regular', sans-serif;
      font-size: 120px;
      text-transform: uppercase;
      color: #fb5f09;
      text-shadow: 0 4px 0 #1b1b1b;
    }
    .bf-hero-discount {
      font-family: 'CCPassThePort Regular', sans-serif;
      color: #fb5f09;
      text-shadow: 0 1px 0 #1b1b1b;
      font-size: 48px;
      line-height: 1;
      position: relative;
      top: 10px;
      padding-bottom: 16px; /* space for underline graphic */
      background-image: url('https://cdn.shopify.com/s/files/1/0431/6663/0052/files/Hand-drawn_pen_scribble.svg?v=1762250681');
      background-repeat: no-repeat;
      background-position: center bottom; /* bottom center underline */
      background-size: 80px 15px; /* tune width/height of scribble */
    }
    .bf-hero-subtitle {
      max-width: 450px;
      margin-left: auto;
      margin-right: auto;

    }
    .bf-hero-subtitle strong { font-weight: 700; }
    .bf-hero-background {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 170%;
      background: linear-gradient(180deg, #f7ece4 67%, rgba(255, 255, 255, 0) 100%);
      z-index: -2;
    }
  .bf-hero-background-2{
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 170%;
    background: linear-gradient(180deg, rgba(255,255,255,0) 70%, rgba(255,255,255,1) 100%);
    z-index: -1;
  }

    .bf-hero-background::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      /* SVG noise overlay; adjust size/opacity to taste */
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='128' height='128'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
      {% comment %} background-size: 220px 220px; /* grain size */ {% endcomment %}
      background-repeat: repeat;
      background-color: #e5d4cc; /* tint color */
      background-blend-mode: multiply;
      opacity: 0.18; /* intensity */
    }
    .position-relative {
      position: relative;
    }
    .bf-hero-image {
      top: 10%;
      position: absolute;
      width: 260px;
      height: 260px;
      object-fit: contain;
    }
    .bf-hero-image--left {
      left: 0;
    }
    .bf-hero-image--right {

      right: 0;
      transform: scaleX(-1);
    }
    .bf-hero-figure {
      position: relative;
      z-index: 10;
      display: block;
      width: 300px;
      height: 200px;
      margin-left: auto;
      margin-right: auto;
      object-fit: contain;
    }
    .bf-hero-line {
      position: absolute;
      bottom: 0;
      width: 100%;
      max-width: 100%;
      height: auto;
      overflow: hidden;
    }
    .bf-hero-section {
      overflow: hidden;
      width: 100%;
      padding-top: 6rem;
    }
    .bf-hero-image-wrapper {
      overflow-x: hidden;
      overflow-y: visible;
      max-width: 100vw;
      position: relative;
    }

    @media (max-width: 1024px) {
      .bf-hero-image {
        top: 10%;
        position: absolute;
        width: 150px;
        height: 150px;
        object-fit: contain;
      }
      .bf-hero-title {
        font-size: 80px;

      }
      .bf-hero-section {

        padding-top: 3rem;
      }
      .bf-hero-discount {

        font-size: 36px;
        top: 5px;
      }
      .bf-hero-figure {

        width: 210px;
        height: 140px;

      }
    }

    @media (max-width: 640px) {
      .bf-hero-image {
        top: 10%;
        position: absolute;
        width: 100px;
        height: 100px;
        object-fit: contain;
      }
      .bf-hero-title {
        font-size: 60px;
      }
      .bf-hero-section {

        padding-top: 4rem;
      }
      .bf-hero-discount {

        font-size: 32px;
        top: 5px;
      }
      .bf-hero-figure {

        width: 180px;
        height: 120px;

      }
      .bf-hero-line {
        width: 200vw;
        max-width: 200vw;
      }
      .bf-hero-line-wrapper {
        position: absolute;
        bottom: 0;
        height: 50%;
        max-height: 50%;
        overflow: hidden;
        width: 100%;
      }
    }
</style>

{% schema %}
{
  "name": "Main Black Friday",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Spooky Deals"
    },
    {
      "type": "text",
      "id": "subtitle_before",
      "label": "Subtitle - text before highlight",
      "default": "Bucură-te de oferte speciale, de până la"
    },
    {
      "type": "text",
      "id": "subtitle_highlight",
      "label": "Subtitle - highlighted text",
      "default": "60%"
    },
    {
      "type": "text",
      "id": "subtitle_after",
      "label": "Subtitle - text after highlight",
      "default": "reducere!"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image (260x260)"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image (260x260)"
    },
    {
      "type": "image_picker",
      "id": "image_figure",
      "label": "Center figure image (300x200)"
    },
    {
      "type": "image_picker",
      "id": "image_line",
      "label": "Bottom line image (wide)"
    }
  ],
  "presets": [
    {
      "name": "Main Black Friday"
    }
  ]
}
{% endschema %}
