<section>
  <div class="global-padding py-6">
    <div class="container-large">
      <div class="overflow-x-auto rounded-[0.25rem] border border-border-primary mb-12">
        <div class="flex items-center gap-3 p-3">
          {% for related_collection in collections %}
            {% if related_collection.metafields.custom.parent_collection != blank %}
              {% assign related_collection_id = related_collection.metafields.custom.parent_collection
                | split: '/'
                | last
                | plus: 0
              %}

              {% if related_collection_id == collection.id %}
                {% render 'subcollection-item', collection: related_collection %}
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="flex items-center gap-3 mb-8">
        <a href="/collections" class="text-text-secondary font-medium global-transition hover:text-text-primary"
          >Collections</a
        >
        {% render 'icon-chevron-right', width: 16, height: 16, class: 'text-text-primary' %}
        <h1 class="text-text-primary font-medium">{{ collection.title }}</h1>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-5">
        <div class="lg:col-span-3">
          <form id="filter-form" novalidate>
            <div class="flex flex-col gap-8 border border-border-primary rounded-xl py-4 lg:py-6 px-4">
              <div class="flex items-center justify-between w-full gap-4">
                <h2 class="heading-h5 text-text-primary">Filtre</h2>
                <div class="flex items-center gap-6">
                  {% assign active_filter_count = 0 %}
                  {% for filter in collection.filters %}
                    {% if filter.active_values.size > 0 or filter.min_value.value or filter.max_value.value %}
                      {% assign active_filter_count = active_filter_count | plus: 1 %}
                    {% endif %}
                  {% endfor %}

                  {% if active_filter_count > 0 %}
                    <a
                      href="{{ collection.url }}?sort_by={{ collection.sort_by }}"
                      class="text-neutral-neutral global-transition hover:text-text-primary"
                    >
                      Șterge filtrele
                    </a>
                  {% endif %}
                  <button class="lg:hidden global-transition" pxm-filter="toggle-filters">
                    {% render 'icon-chevron-down', width: 24, height: 24 %}
                  </button>
                </div>
              </div>
              <div class="hidden lg:flex flex-col gap-8" pxm-filter="filters">
                <p class="text-text-primary font-medium">
                  Se afișează
                  {% if collection.products_count == 1 %}
                    {{ collection.products_count }} produs
                  {% elsif collection.products_count < 20 %}
                    {{ collection.products_count }} produse
                  {% else %}
                    {{ collection.products_count }} de produse
                  {% endif %}
                </p>
                {% for filter in collection.filters %}
                  <div>
                    {% render 'filter-title', title: filter.label %}
                    {% case filter.type %}
                      {% when 'boolean' %}

                      {% when 'list' %}
                        {% case filter.label %}
                          {% when 'Culoare' %}
                            <div class="grid grid-cols-5 gap-2">
                              {% for filter_value in filter.values %}
                                {% render 'filter-color',
                                  index: forloop.index,
                                  id: filter.param_name,
                                  name: filter_value.param_name,
                                  color: filter_value.label,
                                  active: filter_value.active,
                                  value: filter_value.value
                                %}
                              {% endfor %}
                            </div>
                          {% else %}
                            <ul>
                              {% for filter_value in filter.values %}
                                <li>
                                  {% render 'input-checkbox',
                                    index: forloop.index,
                                    id: filter.param_name,
                                    name: filter_value.param_name,
                                    label: filter_value.label,
                                    active: filter_value.active,
                                    value: filter_value.value,
                                    count: filter_value.count
                                  %}
                                </li>
                              {% endfor %}
                            </ul>
                        {% endcase %}
                      {% when 'price_range' %}
                        <div>
                          <div class="flex flex-col">
                            <div class="filter-group-display__price-range">
                              <div class="filter-group-display__price-range-from">
                                <label for="Filter-{{ filter.min_value.param_name }}">De la</label>

                                <input
                                  name="{{ filter.min_value.param_name }}"
                                  id="Filter-{{ filter.min_value.param_name }}"
                                  {% if filter.min_value.value -%}
                                    value="{{ filter.min_value.value | money_without_trailing_zeros | replace: ',', '' }}"
                                  {%- endif %}
                                  type="number"
                                  placeholder="{{0 | money_without_trailing_zeros | replace: ',', ''}}"
                                  min="0"
                                  max="{{ filter.range_max | money_without_trailing_zeros | replace: ',', '' }}"
                                >
                              </div>
                              <div class="filter-group-display__price-range-to">
                                <label for="Filter-{{ filter.max_value.param_name }}">Până la</label>
                                <br>
                                <input
                                  name="{{ filter.max_value.param_name }}"
                                  id="Filter-{{ filter.max_value.param_name }}"
                                  {% if filter.max_value.value -%}
                                    value="{{ filter.max_value.value | money_without_trailing_zeros | replace: ',', '' }}"
                                  {%- endif %}
                                  type="number"
                                  placeholder="{{ filter.range_max | money_without_trailing_zeros | replace: ',', '' }}"
                                  min="0"
                                  max="{{ filter.range_max | money_without_trailing_zeros | replace: ',', '' }}"
                                >
                              </div>
                            </div>
                          </div>
                        </div>
                    {% endcase %}
                  </div>
                {% endfor %}
              </div>
              <div class="flex justify-end">
                <button class="border px-4 py-2 font-bold hover:cursor-pointer" type="submit">Aplică</button>
              </div>
            </div>
            {% comment %} <button type="submit">Apply</button> {% endcomment %}
          </form>
        </div>
        <div class="lg:col-span-9">
          <div class="flex lg:flex-row flex-col justify-end items-center gap-3 mb-12">
            {% render 'filter-search',
              id: 'search',
              name: 'search',
              placeholder: 'Caută produs...',
              class: 'w-full lg:w-[23.75rem]'
            %}

            {% render 'filter-select',
              id: 'sort',
              name: 'sort',
              options: 'Crescător, Descrescător, Preț, Noutăți',
              placeholder: 'Sortează',
              class: 'w-full lg:w-fit'
            %}
          </div>
          <div class="grid grid-cols-2 lg:grid-cols-3 gap-5">
            {% for product in collection.products %}
              {% render 'product-card', product: product %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="hidden" pxm-data="related-collections">
  {% for related_collection in collections %}
    {% if related_collection.metafields.custom.parent_collection != blank %}
      {% assign related_collection_id = related_collection.metafields.custom.parent_collection
        | split: '/'
        | last
        | plus: 0
      %}

      {% if related_collection_id == collection.id %}
        <div pxm-data="related-collection-item">
          <p pxm-item="title">{{ related_collection.title }}</p>
          <p pxm-item="url">{{ related_collection.url }}</p>
        </div>
      {% endif %}
    {% endif %}
  {% endfor %}
</div>

