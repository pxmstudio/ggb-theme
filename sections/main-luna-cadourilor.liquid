<div class="bf-hero-background max-w-full"></div>
<section class="relative bf-hero-section">
  <div class="bf-hero-background-2 max-w-full"></div>
  <img
    src="https://cdn.shopify.com/s/files/1/0431/6663/0052/files/bg_1.png?v=1765352877"
    alt="Black Friday"
    width="100"
    height="100"
    class="bf-hero-image-line"
  >
  <div class="global-padding">
    <div class="container-large flex flex-col lg:flex-row items-center justify-center relative z-10">
      <div class="bf-hero-content flex flex-col items-start justify-start pb-3">
        <p class="bf-hero-subtitle mb-3">{{ section.settings.subtitle | default: 'Dăm startul din 7 Noiembrie!' }}</p>
        <h1 class="bf-hero-title mb-6">{{ section.settings.title | default: 'Black Friday Deals' }}</h1>
        <p class="bf-hero-description mb-8 text-text-primary text-lg font-semibold">
          {{
            section.settings.description
            | default: 'Găsești tot ce ai nevoie pentru o creștere sigură, confortabilă și plină de bucurii!'
          }}
        </p>
        <a href="{{ section.settings.button_link | default: '#offers' }}" class="bf-hero-button">
          {{- section.settings.button_text | default: 'Descoperă ofertele' }}
          <span class="bf-hero-button-icon">{% render 'icon-arrow-right', width: 20, height: 20 -%}</span>
        </a>
      </div>
      <div class="bf-hero-links">
        <a class="bf-hero-link-1" href="{{ section.settings.link1_url | default: '#' }}">
          <img
            src="{{ section.settings.link1_image | image_url: width: 520 | default: 'https://cdn.shopify.com/s/files/1/0431/6663/0052/files/Group_40.png?v=1762440957' }}"
            alt="Black Friday"
            width="260"
            height="260"
            class="bf-hero-link-image"
        ></a>
        <a class="bf-hero-link-2" href="{{ section.settings.link2_url | default: '#' }}"
          ><img
            src="{{ section.settings.link2_image | image_url: width: 780 | default: 'https://cdn.shopify.com/s/files/1/0431/6663/0052/files/Group_38.png?v=1762440958' }}"
            alt="Black Friday"
            width="260"
            height="260"
            class="bf-hero-link-image"
        ></a>
        <a class="bf-hero-link-3" href="{{ section.settings.link3_url | default: '#' }}"
          ><img
            src="{{ section.settings.link3_image | image_url: width: 520 | default: 'https://cdn.shopify.com/s/files/1/0431/6663/0052/files/Group_39.png?v=1762440957' }}"
            alt="Black Friday"
            width="260"
            height="260"
            class="bf-hero-link-image"
        ></a>

        <img
          src="https://cdn.shopify.com/s/files/1/0431/6663/0052/files/Frame_375.png?v=1762440956"
          alt="Black Friday"
          width="100"
          height="100"
          class="bf-hero-image"
        >
        <img
          src="https://cdn.shopify.com/s/files/1/0431/6663/0052/files/Frame_375.png?v=1762440956"
          alt="Black Friday"
          width="100"
          height="100"
          class="bf-hero-image is-secondary"
        >
      </div>
    </div>
  </div>
</section>

<style>
    .bf-hero-section {
      position: relative;
      padding-bottom: 2rem;
      margin-top: 3rem;
      padding-top: 2rem;
      overflow: hidden;
    }
    .bf-hero-subtitle {
      padding: 0.25rem 0.75rem;
      background-color: #fcca1a;
      border-radius: 100px;
      font-size: 14px;
      font-weight: 700;
      color: #383838;
    }
    .bf-hero-title {
      font-size: 5rem;
      font-weight: 800;
      color: #f43636;
      line-height: 1;
    }
    .bf-hero-content {
      max-width: 42%;
      min-width: 42%;
    }
    .bf-hero-button {
      padding: 0.5rem;
      padding-left: 1.5rem;
      background-color: #ea8050;
      border-radius: 100px;
      font-size: 16px;
      font-weight: 600;
      color: #ffffff;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .bf-hero-button-icon {
      display: flex;
      background-color: #ffffff;
      border-radius: 100px;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      color: #ea8050;
    }
    .bf-hero-links {
      left: 10%;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 60%;
      min-width: 60%;
      position: relative;
      aspect-ratio: 7/5;
    }
    .bf-hero-link-1,
    .bf-hero-link-2,
    .bf-hero-link-3 {
      transition: transform 0.2s ease;
    }
    .bf-hero-link-1:hover {
      transform: scale(1.05);
    }
    .bf-hero-link-2:hover {
      transform: scale(1.05);
    }
    .bf-hero-link-3:hover {
      transform: scale(1.05);
    }
    .bf-hero-link-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    .bf-hero-link-1 {
      position: absolute;
      bottom: 25%;
      left: 5%;
      max-width: 30%;
      width: 100%;
      aspect-ratio: 1/1;
      z-index: 3;
    }
    .bf-hero-link-2 {
      position: absolute;
      top: 0%;
      left: auto;
      right: auto;
      max-width: 60%;
      width: 100%;
      aspect-ratio: 1/1;
      z-index: 1;
    }
    .bf-hero-link-3 {
      position: absolute;
      bottom: 10%;
      right: 10%;
      max-width: 30%;
      width: 100%;
      aspect-ratio: 1/1;
      z-index: 2;
    }
    .bf-hero-image {
      position: absolute;
      inset: 0;
      width: 14%;
      aspect-ratio: 1/1;
      object-fit: contain;
      top: 20%;
      left: 18%;
      z-index: 4;
    }
    .bf-hero-image.is-secondary {
      left: auto;
      top: auto;
      bottom: 14%;
      right: 35%;
      z-index: 5;
    }
    .bf-hero-image-line {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 90%%;
      object-fit: cover;
      top: 0%;
      left: 0%;
    }
    .position-relative {
      position: relative;
    }
    .bf-hero-background {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 150vh;
      background: linear-gradient(180deg, #e3d6a9 0%, rgba(255, 255, 255, 0) 100%);
    }
    {% comment %} .bf-hero-background::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='128' height='128'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
      background-repeat: repeat;
      background-size: 200px 200px;
      background-color: #e5ddcc;
      background-blend-mode: multiply;
      opacity: 0.18;
    } {% endcomment %}
    @media (max-width: 1024px) {
      .bf-hero-content {
        max-width: 100%;
        min-width: 100%;
      }
      .bf-hero-links {
        margin-top: 2rem;
        width: 100%;
        min-width: 100%;
        left: 0;
      }
      .bf-hero-image-line {
  bottom: 20%;
        width: 100%;
        top: auto;
        left: 0%;
      }
      .bf-hero-title {
        font-size: 2.5rem;
      }
      .bf-hero-section {
        padding-bottom: 0rem;
      }
    }
</style>

{% comment %}
  <style>
    .bf-hero-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 170%;
        background: linear-gradient(180deg, #f7ece4 67%, rgba(255, 255, 255, 0) 100%);
        z-index: -2;
      }
    .bf-hero-background-2{
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 170%;
      background: linear-gradient(180deg, rgba(255,255,255,0) 70%, rgba(255,255,255,1) 100%);
      z-index: -1;
    }

      .bf-hero-background::after {
        content: '';
        position: absolute;
        inset: 0;
        pointer-events: none;
        /* SVG noise overlay; adjust size/opacity to taste */
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='128' height='128'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
        {% comment %} background-size: 220px 220px; /* grain size */ {% endcomment %}
        background-repeat: repeat;
        background-color: #e5d4cc; /* tint color */
        background-blend-mode: multiply;
        opacity: 0.18; /* intensity */
      }


      @media (max-width: 1024px) {
        .bf-hero-image {
          top: 10%;
          position: absolute;
          width: 150px;
          height: 150px;
          object-fit: contain;
        }
      }

      @media (max-width: 640px) {

        }
  </style>
{% endcomment %}

{% schema %}
{
  "name": "Main Luna Cadourilor",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Dăm startul din 7 Noiembrie!" },
    { "type": "text", "id": "title", "label": "Title", "default": "Black Friday Deals" },
    {
      "type": "textarea",
      "id": "description",
      "label": "Paragraph",
      "default": "Găsești tot ce ai nevoie pentru o creștere sigură, confortabilă și plină de bucurii!"
    },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Descoperă ofertele" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "image_picker", "id": "link1_image", "label": "Card 1 image" },
    { "type": "url", "id": "link1_url", "label": "Card 1 link" },
    { "type": "image_picker", "id": "link2_image", "label": "Card 2 image" },
    { "type": "url", "id": "link2_url", "label": "Card 2 link" },
    { "type": "image_picker", "id": "link3_image", "label": "Card 3 image" },
    { "type": "url", "id": "link3_url", "label": "Card 3 link" }
  ],
  "presets": [{ "name": "Main Luna Cadourilor" }]
}
{% endschema %}
