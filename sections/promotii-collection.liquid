<section id="promotii-collection-{{ section.id }}" class="bf-collection-section position-relative overflow-hidden gog-filters-hidden">
  <div class="global-padding py-6">
    <div class="container-large">
      <div class="flex flex-col bg-white rounded-xl border border-border-primary">
        {% comment %} Pick active collection in this order: forced setting > URL param > current collection > all {% endcomment %}
        {% assign forced_handle = section.settings.forced_collection_handle | strip %}
        {% assign bf_handle = '' %}
        {% if request.query_string contains 'promotii_collection=' %}
          {% assign bf_handle = request.query_string
            | split: 'promotii_collection='
            | last
            | split: '&'
            | first
            | url_decode
          %}
        {% endif %}
        {% if forced_handle != '' and collections[forced_handle] != blank %}
          {% assign active_collection = collections[forced_handle] %}
        {% elsif bf_handle != '' and collections[bf_handle] != blank %}
          {% assign active_collection = collections[bf_handle] %}
        {% elsif collection %}
          {% assign active_collection = collection %}
        {% else %}
          {% assign active_collection = collections.all %}
        {% endif %}

        <div class="lg:col-span-3">
          {% render 'filters-bf',
            location: 'collection',
            collection: active_collection,
            target_section_id: section.id
          %}
        </div>

        <div class="lg:col-span-9">
          <div class="flex flex-col gap-4 lg:p-8 p-4 bf-collection-products">
            {% paginate active_collection.products by section.settings.products_per_page %}
              <div class="grid grid-cols-2 lg:grid-cols-4 gap-5" id="product-grid">
                {% assign initial_rendered = 0 %}

{% if active_collection.handle == 'all' %}

  {% assign rendered_ids = '' %}
  {% assign priority_collections = 'scaune-auto-2,carucioare-bebelusi' | split: ',' %}

  {% for handle in priority_collections %}
    {% assign col = collections[handle] %}
    {% if col != blank %}
      {% assign sorted_products = col.products | sort: 'price' | reverse %}
      {% for product in sorted_products %}
        {% if rendered_ids contains product.id %}
          {% continue %}
        {% endif %}
        {% if product.selected_or_first_available_variant.inventory_quantity <= 0 %}
          {% continue %}
        {% endif %}
        {% assign compare_at = product.compare_at_price_max %}
        {% if compare_at > product.price and compare_at > 0 %}
          {% assign savings = compare_at | minus: product.price %}
          {% assign discount_percent = savings | times: 100 | divided_by: compare_at %}
          {% if discount_percent >= 30 and product.price >= 50000 %}
            {% render 'product-card', product: product %}
            {% assign rendered_ids = rendered_ids | append: product.id | append: ',' %}
            {% assign initial_rendered = initial_rendered | plus: 1 %}
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% assign sorted_active_products = active_collection.products | sort: 'price' | reverse %}
  {% for product in sorted_active_products %}
    {% if rendered_ids contains product.id %}
      {% continue %}
    {% endif %}
    {% if product.selected_or_first_available_variant.inventory_quantity <= 0 %}
      {% continue %}
    {% endif %}
    {% assign compare_at = product.compare_at_price_max %}
    {% if compare_at > product.price and compare_at > 0 %}
      {% assign savings = compare_at | minus: product.price %}
      {% assign discount_percent = savings | times: 100 | divided_by: compare_at %}
      {% if discount_percent >= 30 and product.price >= 50000 %}
        {% render 'product-card', product: product %}
        {% assign initial_rendered = initial_rendered | plus: 1 %}
      {% endif %}
    {% endif %}
  {% endfor %}

{% else %}

  {% assign sorted_active_products = active_collection.products | sort: 'price' | reverse %}
  {% for product in sorted_active_products %}
    {% if product.selected_or_first_available_variant.inventory_quantity <= 0 %}
      {% continue %}
    {% endif %}
    {% assign compare_at = product.compare_at_price_max %}
    {% if compare_at > product.price and compare_at > 0 %}
      {% assign savings = compare_at | minus: product.price %}
      {% assign discount_percent = savings | times: 100 | divided_by: compare_at %}
      {% if discount_percent >= 30 and product.price >= 50000 %}
        {% render 'product-card', product: product %}
        {% assign initial_rendered = initial_rendered | plus: 1 %}
      {% endif %}
    {% endif %}
  {% endfor %}

{% endif %}

              </div>

              {% if initial_rendered == 0 %}
                <p class="text-text-secondary">Nu există produse cu discount ≥ 30% și preț ≥ 500 lei pe această pagină.</p>
              {% endif %}

              {% render 'infinite-scroll-bf',
                next_page: paginate.next.url,
                page_size: paginate.pages,
                collection_url: active_collection.url
              %}
            {% endpaginate %}
          </div>
        </div>
      </div>
    </div>

    <div class="container-large">
      <div class="bf-collection-footer flex center">
        {% render 'button-bf', type: 'link', hierarchy: 'primary', href: '/', text: 'Acasa' %}
      </div>
    </div>
  </div>

  <div class="lc-collection_background max-w-full"></div>
  <div class="lc-collection_background-2 max-w-full"></div>
</section>


{%- comment -%}
  Client-side section replacement removed. The section is rendered server-side
  using the bf_collection query param, so extra fetch + replace is unnecessary
  and could break slider initialization on refresh.
{%- endcomment -%}

<style>
  .bf-collection-products {
    min-height: 50vh;
  }
    .bf-collection-footer {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      padding: 2rem;
      padding-top: 4rem;
    }
    
    .lc-collection_background {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 40rem;
      background: #ffffff;
      z-index: -2;
    }
  .lc-collection_background-2{

    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40rem;
    background: #ffffff;
    z-index: -1;
  }

    .lc-collection_background::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      /* SVG noise overlay; adjust size/opacity to taste */
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='128' height='128'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
      {% comment %} background-size: 220px 220px; /* grain size */ {% endcomment %}
      background-repeat: repeat;
      background-color: #ffffff; /* tint color */
      background-blend-mode: multiply;
      opacity: 0.18; /* intensity */
    }
    @media (max-width: 1024px) {
      .bf-collection-footer-image {
        width: 150px;
        height: 150px;
      }
    }
    @media (max-width: 640px) {
      .bf-collection-footer-image {
        width: 100px;
        height: 100px;
        display: none;
      }
      .bf-collection-footer {
        padding-top: 2rem;
        gap: 1rem;
        padding-bottom: 5rem;
      }
    }
</style>
{%- comment -%}
  Ensure filters-bf.js is loaded whenever this section is present,
  instead of relying on a fragile content_for_layout substring check.
{%- endcomment -%}
<script src="{{ 'filters-bf.js' | asset_url }}" defer></script>
