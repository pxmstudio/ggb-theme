<script>
  (function () {
    const AUTOPLAY_DELAY = 4000;

    function initializeHomeHero(section) {
      if (!section || section.dataset.homeHeroInitialized === 'true') {
        return;
      }
      section.dataset.homeHeroInitialized = 'true';

      const carousel = section.querySelector('[data-home-hero-carousel]');
      const track = section.querySelector('[data-home-hero-track]');
      const slides = Array.from(section.querySelectorAll('[data-home-hero-slide]'));
      const dots = Array.from(section.querySelectorAll('[data-home-hero-dot]'));
      const menu = section.querySelector('[data-home-hero-menu]');

      let currentIndex = 0;
      let autoplayTimer = null;
      let touchStartX = 0;
      let touchEndX = 0;

      function syncHeroHeight() {
        if (!menu) return;
        if (window.innerWidth < 990) {
          section.style.setProperty('--home-hero-dynamic-height', 'auto');
          section.style.setProperty('--home-hero-subcategory-top', '0px');
          return;
        }
        const menuHeight = Math.ceil(menu.scrollHeight);
        section.style.setProperty('--home-hero-dynamic-height', menuHeight + 'px');
      }

      function syncMobileCarouselHeight() {
        if (window.innerWidth >= 990) {
          section.style.removeProperty('--home-hero-mobile-height');
          return;
        }
        const activeSlide = slides[currentIndex];
        if (!activeSlide) return;
        const activeImage = activeSlide.querySelector('.home-hero_slide-image, .home-hero_slide-placeholder');
        if (!activeImage) return;
        const imageHeight = Math.ceil(activeImage.getBoundingClientRect().height);
        if (imageHeight > 0) {
          section.style.setProperty('--home-hero-mobile-height', imageHeight + 'px');
        }
      }

      function setSubcategoryPosition(category) {
        if (!category || !menu || window.innerWidth < 990) {
          section.style.setProperty('--home-hero-subcategory-top', '0px');
          return;
        }
        const categoryTop = Math.max(0, Math.floor(category.offsetTop));
        section.style.setProperty('--home-hero-subcategory-top', categoryTop + 'px');
      }

      function updateCarousel(nextIndex) {
        if (!track || slides.length === 0) {
          return;
        }
        if (nextIndex >= slides.length) {
          currentIndex = 0;
        } else if (nextIndex < 0) {
          currentIndex = slides.length - 1;
        } else {
          currentIndex = nextIndex;
        }
        track.style.transform = 'translate3d(-' + currentIndex * 100 + '%, 0, 0)';
        dots.forEach(function (dot, index) {
          const isActive = index === currentIndex;
          dot.classList.toggle('is-active', isActive);
          dot.setAttribute('aria-current', isActive ? 'true' : 'false');
        });
        syncMobileCarouselHeight();
      }

      function stopAutoplay() {
        if (autoplayTimer) {
          window.clearInterval(autoplayTimer);
          autoplayTimer = null;
        }
      }

      function startAutoplay() {
        stopAutoplay();
        if (slides.length <= 1) {
          return;
        }
        autoplayTimer = window.setInterval(function () {
          updateCarousel(currentIndex + 1);
        }, AUTOPLAY_DELAY);
      }

      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          const nextIndex = Number(dot.dataset.slideIndex);
          updateCarousel(nextIndex);
          startAutoplay();
        });
      });

      if (carousel) {
        carousel.addEventListener('mouseenter', stopAutoplay);
        carousel.addEventListener('mouseleave', startAutoplay);
        carousel.addEventListener('touchstart', function (event) {
          touchStartX = event.touches[0].clientX;
          touchEndX = touchStartX;
          stopAutoplay();
        }, { passive: true });
        carousel.addEventListener('touchmove', function (event) {
          touchEndX = event.touches[0].clientX;
        }, { passive: true });
        carousel.addEventListener('touchend', function () {
          const difference = touchStartX - touchEndX;
          if (Math.abs(difference) > 45) {
            if (difference > 0) {
              updateCarousel(currentIndex + 1);
            } else {
              updateCarousel(currentIndex - 1);
            }
          }
          startAutoplay();
        });
      }

      const subcategoriesWrapper = section.querySelector('[data-home-hero-subcategories-wrapper]');
      const subcategoriesTitle = section.querySelector('[data-home-hero-subcategories-title]');
      const categories = Array.from(section.querySelectorAll('[data-home-hero-category]'));
      const groups = Array.from(section.querySelectorAll('[data-subcategory-group]'));
      let closeTimer = null;

      function closeSubcategories() {
        if (!subcategoriesWrapper) {
          return;
        }
        subcategoriesWrapper.classList.remove('is-active');
        groups.forEach(function (group) {
          group.classList.add('hidden');
        });
      }

      function openSubcategories(category) {
        if (window.innerWidth < 990 || category.dataset.hasSubcategories !== 'true') {
          closeSubcategories();
          return;
        }
        setSubcategoryPosition(category);
        const categoryName = category.dataset.categoryName;
        if (subcategoriesTitle) {
          subcategoriesTitle.textContent = categoryName;
        }
        groups.forEach(function (group) {
          const isCurrent = group.dataset.category === categoryName;
          group.classList.toggle('hidden', !isCurrent);
        });
        if (subcategoriesWrapper) {
          subcategoriesWrapper.classList.add('is-active');
        }
      }

      categories.forEach(function (category) {
        category.addEventListener('mouseenter', function () {
          if (closeTimer) {
            window.clearTimeout(closeTimer);
            closeTimer = null;
          }
          openSubcategories(category);
        });
        category.addEventListener('focus', function () {
          openSubcategories(category);
        });
      });

      if (menu) {
        menu.addEventListener('mouseleave', function () {
          closeTimer = window.setTimeout(closeSubcategories, 120);
        });
        menu.addEventListener('mouseenter', function () {
          if (closeTimer) {
            window.clearTimeout(closeTimer);
            closeTimer = null;
          }
        });
      }

      if (subcategoriesWrapper) {
        subcategoriesWrapper.addEventListener('mouseenter', function () {
          if (closeTimer) {
            window.clearTimeout(closeTimer);
            closeTimer = null;
          }
        });
        subcategoriesWrapper.addEventListener('mouseleave', function () {
          closeTimer = window.setTimeout(closeSubcategories, 120);
        });
      }

      slides.forEach(function (slide) {
        const img = slide.querySelector('.home-hero_slide-image');
        if (img) {
          img.addEventListener('load', function () {
            syncMobileCarouselHeight();
          });
        }
      });

      syncHeroHeight();
      updateCarousel(0);
      syncMobileCarouselHeight();
      startAutoplay();

      window.addEventListener('resize', function () {
        syncHeroHeight();
        updateCarousel(currentIndex);
        syncMobileCarouselHeight();
      });

      window.addEventListener('load', function () {
        syncHeroHeight();
        updateCarousel(currentIndex);
        syncMobileCarouselHeight();
      });

      setTimeout(syncHeroHeight, 250);
      setTimeout(syncHeroHeight, 750);
      setTimeout(syncHeroHeight, 1200);
      setTimeout(syncMobileCarouselHeight, 250);
      setTimeout(syncMobileCarouselHeight, 750);
      setTimeout(syncMobileCarouselHeight, 1200);
    }

    function initializeAllHomeHeroSections() {
      document.querySelectorAll('[data-home-hero-section]').forEach(initializeHomeHero);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeAllHomeHeroSections);
    } else {
      initializeAllHomeHeroSections();
    }

    document.addEventListener('shopify:section:load', function (event) {
      const section = event.target.matches('[data-home-hero-section]')
        ? event.target
        : event.target.querySelector('[data-home-hero-section]');
      initializeHomeHero(section);
    });
  })();
</script>

