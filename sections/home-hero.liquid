<link rel="stylesheet" href="{{ 'home-hero.css' | asset_url }}">
<script defer src="{{ 'home-hero.js' | asset_url }}"></script>

<section class="section_home-hero">
  <div class="global-padding">
    <div class="container-large">
      <div class="padding-section-medium">
        <div class="home-hero_wrapper overflow-hidden">
          <h1 style="display: none;">gogobady</h1>
          <div class="home-hero_left">
            {% for link in linklists['main-menu'].links %}
              {% unless forloop.first or forloop.last %}
                <a
                  href="{{ link.url }}"
                  class="home-hero_category"
                  data-has-subcategories="{% if link.links.size > 0 %}true{% else %}false{% endif %}"
                >
                  <h2 class="home-hero_category-title">{{ link.title }}</h2>
                  {% if link.links.size > 0 %}
                    <svg
                      class="home-hero_category-arrow"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path d="M5 12H19M19 12L12 4.99998M19 12L12 19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {% endif %}
                </a>
              {% endunless %}
            {% endfor %}

            <div class="home-hero_subcategories-wrapper">
              <div class="home-hero_subcategories-inner">
                <h3 class="heading-h4 text-text-primary">Category name</h3>
                <div class="home-hero_subcategories-list" data-subcategories>
                  {% for link in linklists['main-menu'].links %}
                    {% if link.links.size > 0 %}
                      <div class="subcategory-group  hidden" data-category="{{ link.title }}">
                        {% for childlink in link.links %}
                          <a
                            href="{{ childlink.url }}"
                            class="home-hero_subcategories-item hover:bg-brand-orange"
                          >
                            {{- childlink.title -}}
                          </a>
                        {% endfor %}
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>

          <div class="home-hero_right">
            <div class="home-hero_swiper swiper">
              <div class="home-hero_swiper-wrapper swiper-wrapper">
                {% render 'hero-slide' %}
              </div>
              <div class="swiper-pagination home-hero_swiper-pagination"></div>
              <img
                src="https://cdn.shopify.com/s/files/1/0431/6663/0052/files/Group_37_1.png?v=1746008506"
                alt="Corner Decoration"
                width="302"
                height="134"
                loading="lazy"
                class="absolute bottom-0 right-0 h-auto w-[100%] z-10"
                style="width: 40%; pointer-events:none;"
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% comment %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "mainEntity": {
        "@type": "ItemList",
        "name": "Hero Section",
        "itemListElement": [
          {% for link in linklists.categories.links %}
          {
            "@type": "ListItem",
            "position": {{ forloop.index }},
            "name": "{{ link.title }}",
            "url": "{{ link.url }}",
            "itemListElement": [
              {
                "@type": "CategoryCode",
                "codeValue": "{{ link.title }}",
                "name": "Subcategory",
                "url": "your-subcategory-link-here"
              }
            ]
          }{% if forloop.last == false %},{% endif %}
          {% endfor %}
        ]
      },
      "hasPart": {
        "@type": "ImageGallery",
        "name": "Hero Carousel",
        "image": [
          {% for slide in hero_slides %}
          {
            "@type": "ImageObject",
            "url": "{{ slide.image | asset_url }}",
            "name": "Slide {{ forloop.index }}",
            "caption": "Hero slide description {{ forloop.index }}"
          }{% if forloop.last == false %},{% endif %}
          {% endfor %}
        ]
      }
    }
  </script>
{% endcomment %}

{% schema %}
{
  "name": "Home Hero",
  "tag": "section",
  "class": "section_home-hero",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Hero",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
