    }
  }

  document.addEventListener('shopify:section:load', function (event) {
    init(event.target);
  });

  window.HomeHeroForceMotion = {
    init: init,
    replay: function () {
      qsa(document, SECTION_SELECTOR).forEach(function (section) {
        delete section.dataset.srForceInit;
        qsa(section, '[data-sr-force-done="true"]').forEach(function (el) {
