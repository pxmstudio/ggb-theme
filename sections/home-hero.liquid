  .section_home-hero.home-hero-page-fixed .home-hero_category-title,
  .section_home-hero.home-hero-page-fixed .home-hero_category-icon,
  .section_home-hero.home-hero-page-fixed .home-hero_subcategories-title,
  .section_home-hero.home-hero-page-fixed .home-hero_subcategories-item,
  .section_home-hero.home-hero-page-fixed .home-hero_swiper,
  .section_home-hero.home-hero-page-fixed .home-hero_pagination-dot {
    animation: none !important;
    transition: none !important;
    transform: none !important;
    filter: none !important;
    opacity: 1 !important;
  }
}
/* SR-FORCE-ADDED END */
</style>

<script>
/* SR-FORCE-ADDED START: animații directe prin Web Animations API, fără dependență de clase CSS pentru reveal. */
(function () {
  'use strict';

  var SECTION_SELECTOR = '.section_home-hero.home-hero-page-fixed, [data-home-hero-section]';
  var REDUCED = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var HAS_WAAPI = typeof Element !== 'undefined' && Element.prototype && typeof Element.prototype.animate === 'function';
