  }

  function collectItems(section) {
    return {
      menuItems: qsa(section, '.home-hero_category'),
      menuTitles: qsa(section, '.home-hero_category-title'),
      menuIcons: qsa(section, '.home-hero_category-icon'),
      carousel: qsa(section, '.home-hero_swiper'),
      dots: qsa(section, '.home-hero_pagination-dot'),
      subTitles: qsa(section, '.home-hero_subcategories-title'),
      subItems: qsa(section, '.home-hero_subcategories-item')
