<link rel="stylesheet" href="{{ 'home-hero.css' | asset_url }}">

<section
  class="section_home-hero home-hero-full-page"
  data-home-hero-section="{{ section.id }}"
>
  <div class="global-padding">
    <div class="container-large">
      <div class="padding-section-medium">

        <div class="home-hero_wrapper">

          <h1 style="display: none;">gogobaby</h1>

          <!-- Categorii -->
          <div class="home-hero_left" data-home-hero-menu>

            {% for link in linklists['main-menu'].links %}
              {% unless forloop.first or forloop.last %}

                <a
                  href="{{ link.url }}"
                  class="home-hero_category"
                  data-home-hero-category
                  data-category-name="{{ link.title | escape }}"
                  data-has-subcategories="{% if link.links.size > 0 %}true{% else %}false{% endif %}"
                >
                  <span class="home-hero_category-icon" aria-hidden="true">
                    <svg
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M4 7.5H20M6 7.5L7.3 19H16.7L18 7.5M9 7.5V5.8C9 4.25 10.25 3 11.8 3H12.2C13.75 3 15 4.25 15 5.8V7.5"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>

                  <h2 class="home-hero_category-title">
                    {{ link.title }}
                  </h2>

                  {% if link.links.size > 0 %}
                    <svg
                      class="home-hero_category-arrow"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M9 5L16 12L9 19"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  {% endif %}
                </a>

              {% endunless %}
            {% endfor %}

            <!-- Subcategorii -->
            <div
              class="home-hero_subcategories-wrapper"
              data-home-hero-subcategories-wrapper
            >
              <div class="home-hero_subcategories-inner">

                <h3
                  class="heading-h4 text-text-primary"
                  data-home-hero-subcategories-title
                >
                  Category name
                </h3>

                <div
                  class="home-hero_subcategories-list"
                  data-subcategories
                >
                  {% for link in linklists['main-menu'].links %}

                    {% if link.links.size > 0 %}
                      <div
                        class="subcategory-group hidden"
                        data-subcategory-group
                        data-category="{{ link.title | escape }}"
                      >
                        {% for childlink in link.links %}
                          <a
                            href="{{ childlink.url }}"
                            class="home-hero_subcategories-item hover:bg-brand-orange"
                          >
                            {{ childlink.title }}
                          </a>
                        {% endfor %}
                      </div>
                    {% endif %}

                  {% endfor %}
                </div>

              </div>
            </div>

          </div>

          <!-- Carusel -->
          <div class="home-hero_right">

            <div
              class="home-hero_swiper"
              data-home-hero-carousel
            >

              <div
                class="home-hero_swiper-wrapper"
                data-home-hero-track
              >

                {% for block in section.blocks %}

                  {% if block.type == 'slide' %}

                    {% assign image_loading = 'lazy' %}

                    {% if forloop.first %}
                      {% assign image_loading = 'eager' %}
                    {% endif %}

                    <div
                      class="home-hero_slide"
                      data-home-hero-slide
                      {{ block.shopify_attributes }}
                    >

                      {% if block.settings.link != blank %}
                        <a
                          href="{{ block.settings.link }}"
                          class="home-hero_slide-link"
                        >
                      {% endif %}

                      {% if block.settings.image != blank %}

                        {% assign image_alt = block.settings.image.alt
                          | default: 'Banner promoțional'
                        %}

                        <img
                          src="{{ block.settings.image | image_url: width: 1400 }}"
                          srcset="
                            {{ block.settings.image | image_url: width: 700 }} 700w,
                            {{ block.settings.image | image_url: width: 1000 }} 1000w,
                            {{ block.settings.image | image_url: width: 1400 }} 1400w,
                            {{ block.settings.image | image_url: width: 1800 }} 1800w,
                            {{ block.settings.image | image_url: width: 2200 }} 2200w
                          "
                          sizes="(min-width: 990px) calc(100vw - 232px), 100vw"
                          alt="{{ image_alt | escape }}"
                          class="home-hero_slide-image"
                          loading="{{ image_loading }}"
                          width="{{ block.settings.image.width }}"
                          height="{{ block.settings.image.height }}"
                        >

                      {% else %}

                        {{ 'lifestyle-1'
                          | placeholder_svg_tag:
                            'home-hero_slide-placeholder'
                        }}

                      {% endif %}

                      {% if block.settings.link != blank %}
                        </a>
                      {% endif %}

                    </div>

                  {% endif %}

                {% endfor %}

              </div>

              <!-- Puncte navigare -->
              <div
                class="home-hero_swiper-pagination"
                data-home-hero-pagination
                aria-label="Navigare carusel"
              >
                {% for block in section.blocks %}
                  {% if block.type == 'slide' %}
                    <button
                      type="button"
                      class="home-hero_pagination-dot{% if forloop.first %} is-active{% endif %}"
                      data-home-hero-dot
                      data-slide-index="{{ forloop.index0 }}"
                      aria-label="Afișează imaginea {{ forloop.index }}"
                    ></button>
                  {% endif %}
                {% endfor %}
              </div>

            </div>

          </div>

        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /*
    HOME HERO FULL PAGE
    - meniu categorii în stânga
    - carusel mare în dreapta
    - layout pe toată lățimea paginii
    - fără carusel pătrat
    - imagine setată pe cover
  */

  html,
