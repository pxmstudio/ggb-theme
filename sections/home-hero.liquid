  .section_home-hero.home-hero-full-page .container-large,
  .section_home-hero.home-hero-full-page .padding-section-medium {
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .section_home-hero.home-hero-full-page *,
