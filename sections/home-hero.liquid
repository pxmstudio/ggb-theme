<link rel="stylesheet" href="{{ 'home-hero.css' | asset_url }}">

<section
  class="section_home-hero"
  data-home-hero-section="{{ section.id }}"
>
  <div class="global-padding">
    <div class="container-large">
      <div class="padding-section-medium">

        <div class="home-hero_wrapper overflow-hidden">

          <h1 style="display: none;">gogobaby</h1>

          <!-- Categorii -->
          <div class="home-hero_left" data-home-hero-menu>

            {% for link in linklists['main-menu'].links %}
              {% unless forloop.first or forloop.last %}

                <a
                  href="{{ link.url }}"
                  class="home-hero_category"
                  data-home-hero-category
                  data-category-name="{{ link.title | escape }}"
                  data-has-subcategories="{% if link.links.size > 0 %}true{% else %}false{% endif %}"
                >
                  <h2 class="home-hero_category-title">
                    {{ link.title }}
                  </h2>

                  {% if link.links.size > 0 %}
                    <svg
                      class="home-hero_category-arrow"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M5 12H19M19 12L12 4.99998M19 12L12 19"
                        stroke="white"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  {% endif %}
                </a>

              {% endunless %}
            {% endfor %}

            <!-- Subcategorii -->
            <div
              class="home-hero_subcategories-wrapper"
              data-home-hero-subcategories-wrapper
            >
              <div class="home-hero_subcategories-inner">

                <h3
                  class="heading-h4 text-text-primary"
                  data-home-hero-subcategories-title
                >
                  Category name
                </h3>

                <div
                  class="home-hero_subcategories-list"
                  data-subcategories
                >
                  {% for link in linklists['main-menu'].links %}

                    {% if link.links.size > 0 %}
                      <div
                        class="subcategory-group hidden"
                        data-subcategory-group
                        data-category="{{ link.title | escape }}"
                      >
                        {% for childlink in link.links %}
                          <a
                            href="{{ childlink.url }}"
                            class="home-hero_subcategories-item hover:bg-brand-orange"
                          >
                            {{ childlink.title }}
                          </a>
                        {% endfor %}
                      </div>
                    {% endif %}

                  {% endfor %}
                </div>

              </div>
            </div>

          </div>

          <!-- Carusel -->
          <div class="home-hero_right">

            <div
              class="home-hero_swiper"
              data-home-hero-carousel
            >

              <div
                class="home-hero_swiper-wrapper"
                data-home-hero-track
              >

                {% for block in section.blocks %}

                  {% if block.type == 'slide' %}

                    {% assign image_loading = 'lazy' %}

                    {% if forloop.first %}
                      {% assign image_loading = 'eager' %}
                    {% endif %}

                    <div
                      class="home-hero_slide"
                      data-home-hero-slide
                      {{ block.shopify_attributes }}
                    >

                      {% if block.settings.link != blank %}
                        <a
                          href="{{ block.settings.link }}"
                          class="home-hero_slide-link"
                        >
                      {% endif %}

                      {% if block.settings.image != blank %}

                        {% assign image_alt = block.settings.image.alt
                          | default: 'Banner promoțional'
                        %}

                        <img
                          src="{{ block.settings.image | image_url: width: 1000 }}"
                          srcset="
                            {{ block.settings.image | image_url: width: 600 }} 600w,
                            {{ block.settings.image | image_url: width: 900 }} 900w,
                            {{ block.settings.image | image_url: width: 1200 }} 1200w,
                            {{ block.settings.image | image_url: width: 1800 }} 1800w
                          "
                          sizes="(min-width: 990px) 55vw, 86vw"
                          alt="{{ image_alt | escape }}"
                          class="home-hero_slide-image"
                          loading="{{ image_loading }}"
                          width="{{ block.settings.image.width }}"
                          height="{{ block.settings.image.height }}"
                        >

                      {% else %}

                        {{ 'lifestyle-1'
                          | placeholder_svg_tag:
                            'home-hero_slide-placeholder'
                        }}

                      {% endif %}

                      {% if block.settings.link != blank %}
                        </a>
                      {% endif %}

                    </div>

                  {% endif %}

                {% endfor %}

              </div>

              <!-- Puncte navigare -->
              <div
                class="home-hero_swiper-pagination"
                data-home-hero-pagination
                aria-label="Navigare carusel"
              >
                {% for block in section.blocks %}
                  {% if block.type == 'slide' %}
                    <button
                      type="button"
                      class="home-hero_pagination-dot{% if forloop.first %} is-active{% endif %}"
                      data-home-hero-dot
                      data-slide-index="{{ forloop.index0 }}"
                      aria-label="Afișează imaginea {{ forloop.index }}"
                    ></button>
                  {% endif %}
                {% endfor %}
              </div>

            </div>

          </div>

        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /*
    CARUSEL FIXAT
    Desktop:
    - o singură imagine centrată
    - spațiu redus în jur
    - nav peste imagine
    - colțuri rotunde

    Modifică dimensiunea desktop de aici:
    --home-hero-carousel-width: 55%;
  */

  .home-hero_right {
    --home-hero-carousel-width: 55%;
    --home-hero-carousel-radius: 24px;

    min-width: 0 !important;
    height: auto !important;
    min-height: 0 !important;
    overflow: visible !important;

    display: flex !important;
    align-items: flex-start !important;
    justify-content: center !important;
  }

  .home-hero_swiper {
    position: relative !important;
    display: block !important;

    width: var(--home-hero-carousel-width) !important;
    max-width: var(--home-hero-carousel-width) !important;

    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    aspect-ratio: auto !important;

    overflow: hidden !important;
    border-radius: var(--home-hero-carousel-radius) !important;

    isolation: isolate !important;
    line-height: 0 !important;
    touch-action: pan-y;
  }

  .home-hero_swiper-wrapper {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
    align-items: flex-start !important;

    width: 100% !important;
    max-width: 100% !important;

    height: auto !important;
    min-height: 0 !important;

    overflow: hidden !important;
    border-radius: var(--home-hero-carousel-radius) !important;

    transform: translate3d(0, 0, 0);
    transition: transform 0.55s ease;
    will-change: transform;
  }

  .home-hero_slide {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;

    flex: 0 0 100% !important;
    width: 100% !important;
    min-width: 100% !important;
    max-width: 100% !important;

    height: auto !important;
    min-height: 0 !important;

    overflow: hidden !important;
    border-radius: var(--home-hero-carousel-radius) !important;

    box-sizing: border-box !important;
    line-height: 0 !important;
  }

  .home-hero_slide-link {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;

    width: 100% !important;
    height: auto !important;

    overflow: hidden !important;
    border-radius: var(--home-hero-carousel-radius) !important;

    line-height: 0 !important;
  }

  .home-hero_slide-image,
  .home-hero_slide-placeholder {
    display: block !important;

    width: 100% !important;
    max-width: 100% !important;

    height: auto !important;
    max-height: none !important;

    margin: 0 auto !important;

    border-radius: var(--home-hero-carousel-radius) !important;
    object-fit: cover !important;
  }

  /*
    PUNCTE NAVIGARE
  */

  .home-hero_swiper-pagination {
    position: absolute !important;
    right: 0 !important;
    bottom: 14px !important;
    left: 0 !important;
    z-index: 999 !important;

    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;

    width: 100% !important;
    height: auto !important;

    pointer-events: auto !important;
    line-height: 1 !important;
  }

  .home-hero_pagination-dot {
    display: block !important;

    width: 8px !important;
    min-width: 8px !important;
    height: 8px !important;
    min-height: 8px !important;

    padding: 0 !important;
    margin: 0 !important;

    border: 0 !important;
    border-radius: 999px !important;

    background-color: rgba(255, 255, 255, 0.8) !important;
    box-shadow: 0 1px 5px rgba(0, 0, 0, 0.35) !important;

    opacity: 1 !important;
    visibility: visible !important;
    cursor: pointer !important;

    transition:
      width 0.25s ease,
      border-radius 0.25s ease,
      background-color 0.25s ease;
  }

  .home-hero_pagination-dot.is-active {
    width: 24px !important;
    min-width: 24px !important;
    border-radius: 999px !important;
    background-color: #ffffff !important;
  }

  /*
    SUBCATEGORII
  */

  .home-hero_subcategories-wrapper {
    display: none;
  }

  .home-hero_subcategories-wrapper.is-active {
    display: block;
  }

  /*
    MOBIL
    Modifică dimensiunea mobil de aici:
    --home-hero-carousel-width: 86%;
  */

  @media screen and (max-width: 989px) {
    .home-hero_right {
      --home-hero-carousel-width: 86%;
      --home-hero-carousel-radius: 18px;

      width: 100% !important;
      min-width: 0 !important;
      height: auto !important;
      min-height: 0 !important;

      display: flex !important;
      align-items: center !important;
      justify-content: center !important;

      overflow: visible !important;
    }

    .home-hero_swiper {
      position: relative !important;

      width: var(--home-hero-carousel-width) !important;
      max-width: var(--home-hero-carousel-width) !important;

      height: auto !important;
      min-height: 0 !important;
      max-height: none !important;

      overflow: hidden !important;
      border-radius: var(--home-hero-carousel-radius) !important;

      isolation: isolate !important;
      line-height: 0 !important;
    }

    .home-hero_swiper-wrapper {
      height: auto !important;
      min-height: 0 !important;

      border-radius: var(--home-hero-carousel-radius) !important;
      overflow: hidden !important;
    }

    .home-hero_slide {
      height: auto !important;
      min-height: 0 !important;

      border-radius: var(--home-hero-carousel-radius) !important;
      overflow: hidden !important;
    }

    .home-hero_slide-link {
      height: auto !important;

      border-radius: var(--home-hero-carousel-radius) !important;
      overflow: hidden !important;
    }

    .home-hero_slide-image,
    .home-hero_slide-placeholder {
      width: 100% !important;
      max-width: 100% !important;

      height: auto !important;
      max-height: none !important;

      display: block !important;

      border-radius: var(--home-hero-carousel-radius) !important;
      overflow: hidden !important;

      object-fit: cover !important;
    }

    .home-hero_swiper-pagination {
      position: absolute !important;
      left: 0 !important;
      right: 0 !important;
      bottom: 12px !important;

      z-index: 999 !important;

      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 8px !important;

      width: 100% !important;
      height: auto !important;

      opacity: 1 !important;
      visibility: visible !important;

      pointer-events: auto !important;
      line-height: 1 !important;
    }

    .home-hero_pagination-dot {
      display: block !important;

      width: 8px !important;
      min-width: 8px !important;
      height: 8px !important;
      min-height: 8px !important;

      padding: 0 !important;
      margin: 0 !important;

      border: 0 !important;
      border-radius: 999px !important;

      background-color: rgba(255, 255, 255, 0.85) !important;
      box-shadow: 0 1px 5px rgba(0, 0, 0, 0.35) !important;

      opacity: 1 !important;
      visibility: visible !important;
    }

    .home-hero_pagination-dot.is-active {
      width: 22px !important;
      min-width: 22px !important;
      background-color: #ffffff !important;
    }
  }
</style>

<script>
  (function () {
    const AUTOPLAY_DELAY = 4000;

    function initializeHomeHero(section) {
      if (!section || section.dataset.homeHeroInitialized === 'true') {
        return;
      }

      section.dataset.homeHeroInitialized = 'true';

      const carousel = section.querySelector('[data-home-hero-carousel]');
      const track = section.querySelector('[data-home-hero-track]');
      const slides = Array.from(
        section.querySelectorAll('[data-home-hero-slide]')
      );
      const dots = Array.from(
        section.querySelectorAll('[data-home-hero-dot]')
      );

      let currentIndex = 0;
      let autoplayTimer = null;
      let touchStartX = 0;
      let touchEndX = 0;

      function updateCarousel(nextIndex) {
        if (!track || slides.length === 0) {
          return;
        }

        if (nextIndex >= slides.length) {
          currentIndex = 0;
        } else if (nextIndex < 0) {
          currentIndex = slides.length - 1;
        } else {
          currentIndex = nextIndex;
        }

        track.style.transform =
          'translate3d(-' + currentIndex * 100 + '%, 0, 0)';

        dots.forEach(function (dot, index) {
          const isActive = index === currentIndex;

          dot.classList.toggle('is-active', isActive);
          dot.setAttribute(
            'aria-current',
            isActive ? 'true' : 'false'
          );
        });
      }

      function stopAutoplay() {
        if (autoplayTimer) {
          window.clearInterval(autoplayTimer);
          autoplayTimer = null;
        }
      }

      function startAutoplay() {
        stopAutoplay();

        if (slides.length <= 1) {
          return;
        }

        autoplayTimer = window.setInterval(function () {
          updateCarousel(currentIndex + 1);
        }, AUTOPLAY_DELAY);
      }

      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          const nextIndex = Number(dot.dataset.slideIndex);

          updateCarousel(nextIndex);
          startAutoplay();
        });
      });

      if (carousel) {
        carousel.addEventListener('mouseenter', stopAutoplay);
        carousel.addEventListener('mouseleave', startAutoplay);

        carousel.addEventListener(
          'touchstart',
          function (event) {
            touchStartX = event.touches[0].clientX;
            touchEndX = touchStartX;
            stopAutoplay();
          },
          { passive: true }
        );

        carousel.addEventListener(
          'touchmove',
          function (event) {
            touchEndX = event.touches[0].clientX;
          },
          { passive: true }
        );

        carousel.addEventListener('touchend', function () {
          const difference = touchStartX - touchEndX;

          if (Math.abs(difference) > 45) {
            if (difference > 0) {
              updateCarousel(currentIndex + 1);
            } else {
              updateCarousel(currentIndex - 1);
            }
          }

          startAutoplay();
        });
      }

      updateCarousel(0);
      startAutoplay();

      window.addEventListener('resize', function () {
        updateCarousel(currentIndex);
      });

      /*
        MENIU CATEGORII ȘI SUBCATEGORII
      */

      const menu = section.querySelector('[data-home-hero-menu]');
      const subcategoriesWrapper = section.querySelector(
        '[data-home-hero-subcategories-wrapper]'
      );
      const subcategoriesTitle = section.querySelector(
        '[data-home-hero-subcategories-title]'
      );
      const categories = Array.from(
        section.querySelectorAll('[data-home-hero-category]')
      );
      const groups = Array.from(
        section.querySelectorAll('[data-subcategory-group]')
      );

      function closeSubcategories() {
        if (!subcategoriesWrapper) {
          return;
        }

        subcategoriesWrapper.classList.remove('is-active');

        groups.forEach(function (group) {
          group.classList.add('hidden');
        });
      }

      categories.forEach(function (category) {
        category.addEventListener('mouseenter', function () {
          if (
            window.innerWidth < 990 ||
            category.dataset.hasSubcategories !== 'true'
          ) {
            return;
          }

          const categoryName = category.dataset.categoryName;

          if (subcategoriesTitle) {
            subcategoriesTitle.textContent = categoryName;
          }

          groups.forEach(function (group) {
            const isCurrent =
              group.dataset.category === categoryName;

            group.classList.toggle('hidden', !isCurrent);
          });

          if (subcategoriesWrapper) {
            subcategoriesWrapper.classList.add('is-active');
          }
        });
      });

      if (menu) {
        menu.addEventListener('mouseleave', closeSubcategories);
      }
    }

    function initializeAllHomeHeroSections() {
      document
        .querySelectorAll('[data-home-hero-section]')
        .forEach(initializeHomeHero);
    }

    if (document.readyState === 'loading') {
      document.addEventListener(
        'DOMContentLoaded',
        initializeAllHomeHeroSections
      );
    } else {
      initializeAllHomeHeroSections();
    }

    document.addEventListener(
      'shopify:section:load',
      function (event) {
        const section =
          event.target.matches('[data-home-hero-section]')
            ? event.target
            : event.target.querySelector('[data-home-hero-section]');

        initializeHomeHero(section);
      }
    );
  })();
</script>

{% schema %}
{
  "name": "Home Hero",
  "tag": "section",
  "class": "section_home-hero",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagine"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Hero",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}