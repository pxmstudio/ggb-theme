<link rel="stylesheet" href="{{ 'home-hero.css' | asset_url }}">

<section class="section_home-hero home-hero-page-fixed" data-home-hero-section="{{ section.id }}">
  <div class="container-large">
    <div class="padding-section-medium">
      <div class="home-hero_wrapper">
        <h1 style="display: none;">gogobaby</h1>

        <!-- MENIU CATEGORII -->
        <div class="home-hero_left" data-home-hero-menu>
          {%- assign fallback_icons = 'star,balloon,cloud,moon,flower,smile,leaf,cup,music,book,crown,bell,umbrella,camera,key' | split: ',' -%}
          {%- assign fallback_index = 0 -%}
          {% for link in linklists['main-menu'].links %}
            {% unless forloop.first or forloop.last or link.title == blank %}
              {% assign title_downcase = link.title | downcase %}
              {% assign category_icon = '' %}

              {% if title_downcase contains 'mamic' or title_downcase contains 'mămic' or title_downcase contains 'gravid' or title_downcase contains 'maternitate' %}
                {% assign category_icon = 'heart' %}
              {% elsif title_downcase contains 'scaun auto' or title_downcase contains 'scaune auto' %}
                {% assign category_icon = 'carseat' %}
              {% elsif title_downcase contains 'caruci' or title_downcase contains 'căruci' or title_downcase contains 'landou' %}
                {% assign category_icon = 'transport' %}
              {% elsif title_downcase contains 'transport' %}
                {% assign category_icon = 'suitcase' %}
              {% elsif title_downcase contains 'accesorii' and title_downcase contains 'patut' or title_downcase contains 'accesorii' and title_downcase contains 'pătuț' %}
                {% assign category_icon = 'pillow' %}
              {% elsif title_downcase contains 'patut' or title_downcase contains 'pătuț' or title_downcase contains 'tarc' or title_downcase contains 'țarc' %}
                {% assign category_icon = 'room' %}
              {% elsif title_downcase contains 'camera' or title_downcase contains 'cameră' %}
                {% assign category_icon = 'home' %}
              {% elsif title_downcase contains 'siguranta' or title_downcase contains 'siguranța' or title_downcase contains 'protect' %}
                {% assign category_icon = 'safety' %}
              {% elsif title_downcase contains 'hranire' or title_downcase contains 'hrănire' or title_downcase contains 'alaptare' or title_downcase contains 'alăptare' or title_downcase contains 'alimentat' or title_downcase contains 'biberon' or title_downcase contains 'masă' %}
                {% assign category_icon = 'feeding' %}
              {% elsif title_downcase contains 'igiena' or title_downcase contains 'igienă' or title_downcase contains 'sanatate' or title_downcase contains 'sănătate' or title_downcase contains 'curat' or title_downcase contains 'sanatos' or title_downcase contains 'sănătos' or title_downcase contains 'baie' or title_downcase contains 'scutec' or title_downcase contains 'cosmetice' or title_downcase contains 'ingrijire' or title_downcase contains 'îngrijire' %}
                {% assign category_icon = 'hygiene' %}
              {% elsif title_downcase contains 'exterior' %}
                {% assign category_icon = 'outdoor' %}
              {% elsif title_downcase contains 'activitat' or title_downcase contains 'activități' or title_downcase contains 'activitate' %}
                {% assign category_icon = 'rattle' %}
              {% elsif title_downcase contains 'triciclet' %}
                {% assign category_icon = 'tricycle' %}
              {% elsif title_downcase contains 'biciclet' or title_downcase contains 'trotinet' %}
                {% assign category_icon = 'bike' %}
              {% elsif title_downcase contains 'vehicul' or title_downcase contains 'masinut' or title_downcase contains 'mașinuț' %}
                {% assign category_icon = 'car' %}
              {% elsif title_downcase contains 'jucarii' or title_downcase contains 'jucării' or title_downcase contains 'jocuri' or title_downcase contains 'joaca' or title_downcase contains 'joacă' %}
                {% assign category_icon = 'toys' %}
              {% elsif title_downcase contains 'reduceri' or title_downcase contains 'reducer' or title_downcase contains 'oferte' or title_downcase contains 'promo' or title_downcase contains 'outlet' or title_downcase contains 'resigilat' %}
                {% assign category_icon = 'discount' %}
              {% elsif title_downcase contains 'parinti' or title_downcase contains 'părinți' %}
                {% assign category_icon = 'parents' %}
              {% elsif title_downcase contains 'hainut' or title_downcase contains 'hăinuț' or title_downcase contains 'haine' or title_downcase contains 'imbracaminte' or title_downcase contains 'îmbrăcăminte' or title_downcase contains 'incaltaminte' or title_downcase contains 'încălțăminte' or title_downcase contains 'body' %}
                {% assign category_icon = 'clothes' %}
              {% elsif title_downcase contains 'cadou' %}
                {% assign category_icon = 'gifts' %}
              {% elsif title_downcase contains 'plimbare' or title_downcase contains 'relaxare' %}
                {% assign category_icon = 'walk' %}
              {% elsif title_downcase contains 'gradinita' or title_downcase contains 'grădinița' or title_downcase contains 'scoala' or title_downcase contains 'școala' or title_downcase contains 'ghiozdan' or title_downcase contains 'rechizite' %}
                {% assign category_icon = 'school' %}
              {% endif %}

              {% if category_icon == '' %}
                {% assign fb = fallback_index | modulo: fallback_icons.size %}
                {% assign category_icon = fallback_icons[fb] %}
                {% assign fallback_index = fallback_index | plus: 1 %}
              {% endif %}

              <a href="{{ link.url }}"
                 class="home-hero_category"
                 data-home-hero-category
                 data-category-name="{{ link.title | escape }}"
                 data-has-subcategories="{% if link.links.size > 0 %}true{% else %}false{% endif %}">
                <span class="home-hero_category-icon" aria-hidden="true">
                  {%- case category_icon -%}
                    {%- when 'transport' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h1.6a1 1 0 0 1 .96.72L9 12"/><path d="M20 4a9 9 0 0 0-9 8h8a1 1 0 0 0 1-1V4z"/><path d="M9 12l-2 5"/><path d="M15 12v5"/><circle cx="7" cy="19" r="2"/><circle cx="17" cy="19" r="2"/></svg>
                    {%- when 'feeding' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6"/><path d="M10 3v2.4c0 .5-.2 1-.55 1.35L8 8.2V20a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V8.2l-1.45-1.45A1.9 1.9 0 0 1 14 5.4V3"/><path d="M8 11h8"/><path d="M9 14.5h3.5"/></svg>
                    {%- when 'room' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8v11"/><path d="M21 8v11"/><path d="M3 13h18"/><path d="M3 10h18"/><path d="M6 8V6"/><path d="M9.5 8V6"/><path d="M13 8V6"/><path d="M16.5 8V6"/></svg>
                    {%- when 'parents' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 5.3a3.2 3.2 0 0 1 0 5.4"/><path d="M17 15.2A5.5 5.5 0 0 1 20.5 20"/></svg>
                    {%- when 'clean' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 3l1.7 4.3L17 9l-4.3 1.7L11 15l-1.7-4.3L5 9l4.3-1.7z"/><path d="M18 14l.8 2 2 .8-2 .8-.8 2-.8-2-2-.8 2-.8z"/></svg>
                    {%- when 'clothes' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 3L5 5.5 3 9l3 1.5V20a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-9.5L21 9l-2-3.5L15.5 3a3.5 3.5 0 0 1-7 0z"/></svg>
                    {%- when 'outdoor' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
                    {%- when 'toys' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="6" r="2"/><circle cx="17" cy="6" r="2"/><circle cx="12" cy="13" r="7"/><circle cx="9.5" cy="12" r=".6"/><circle cx="14.5" cy="12" r=".6"/><path d="M10.3 15.3a2.2 2.2 0 0 0 3.4 0"/></svg>
                    {%- when 'gifts' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M5 12v9h14v-9"/><path d="M12 8v13"/><path d="M12 8S10.5 3 8 4.5 9.5 8 12 8z"/><path d="M12 8s1.5-5 4-3.5S14.5 8 12 8z"/></svg>
                    {%- when 'walk' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="4.2" r="1.9"/><path d="M9 21l3-6 3 6"/><path d="M6 9l6 2 6-2"/><path d="M12 11v4"/></svg>
                    {%- when 'safety' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
                    {%- when 'school' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0v11a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1z"/><path d="M9 8a3 3 0 0 1 6 0"/><path d="M6 13h12"/><path d="M10 13v3h4v-3"/></svg>
                    {%- when 'hygiene' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11z"/></svg>
                    {%- when 'bike' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="17" r="3.5"/><circle cx="18" cy="17" r="3.5"/><path d="M6 17l4-8h5l2.8 8"/><path d="M10 9l3 8"/><path d="M9 6h3l1 3"/></svg>
                    {%- when 'car' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 13l2-5a2 2 0 0 1 1.9-1.3h10.2A2 2 0 0 1 19 8l2 5"/><path d="M3 13h18v4a1 1 0 0 1-1 1h-1.5a1 1 0 0 1-1-1v-1H6.5v1a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/><circle cx="7" cy="15.5" r=".5"/><circle cx="17" cy="15.5" r=".5"/></svg>
                    {%- when 'box' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l9-4 9 4-9 4z"/><path d="M3 8v8l9 4 9-4V8"/><path d="M12 12v8"/></svg>
                    {%- when 'heart' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20s-7-4.3-9-8.5A4.5 4.5 0 0 1 12 6a4.5 4.5 0 0 1 9 5.5c-2 4.2-9 8.5-9 8.5z"/></svg>
                    {%- when 'star' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5l2.4 5 5.4.6-4 3.7 1.1 5.3L12 15.4 7.1 18l1.1-5.3-4-3.7 5.4-.6z"/></svg>
                    {%- when 'balloon' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 14.5c3.2 0 5.5-2.9 5.5-6.2A5.5 5.5 0 0 0 6.5 8.3c0 3.3 2.3 6.2 5.5 6.2z"/><path d="M12 14.5v2.5"/><path d="M11 21c1-.6 1.8-1.6 1-3"/></svg>
                    {%- when 'cloud' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 18a4.2 4.2 0 0 1-.3-8.4A5.2 5.2 0 0 1 17 8.6a3.7 3.7 0 0 1-.2 9.4z"/></svg>
                    {%- when 'moon' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13.6A8 8 0 1 1 10.4 4a6.2 6.2 0 0 0 9.6 9.6z"/></svg>
                    {%- when 'flower' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><circle cx="12" cy="6.6" r="2.2"/><circle cx="16.8" cy="10.2" r="2.2"/><circle cx="15" cy="16" r="2.2"/><circle cx="9" cy="16" r="2.2"/><circle cx="7.2" cy="10.2" r="2.2"/></svg>
                    {%- when 'smile' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8.5"/><path d="M8.8 14a3.6 3.6 0 0 0 6.4 0"/><circle cx="9" cy="10" r=".7"/><circle cx="15" cy="10" r=".7"/></svg>
                    {%- when 'leaf' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 19C5 11 11 5 19 5c0 8-6 14-14 14z"/><path d="M6 18c3.5-6 7.5-8.5 11-10.5"/></svg>
                    {%- when 'cup' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h11v5.5a4 4 0 0 1-4 4H9a4 4 0 0 1-4-4z"/><path d="M16 9.5h2a2 2 0 0 1 0 4h-2"/><path d="M7.5 4.5v2M10 4v2M12.5 4.5v2"/></svg>
                    {%- when 'music' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 17.5V6l9-2v11.5"/><circle cx="7" cy="17.5" r="2"/><circle cx="16" cy="15.5" r="2"/></svg>
                    {%- when 'book' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6.5C10 5.2 7.5 5 5 5.5v13c2.5-.5 5-.3 7 1 2-1.3 4.5-1.5 7-1v-13c-2.5-.5-5-.3-7 1z"/><path d="M12 6.5v13"/></svg>
                    {%- when 'crown' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8.5l3.2 8h9.6l3.2-8-4.7 3.6L12 6 8.7 12.1z"/><path d="M6.5 19.5h11"/></svg>
                    {%- when 'bell' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 16.5V11a6 6 0 0 1 12 0v5.5l1.4 1.8H4.6z"/><path d="M10 20a2 2 0 0 0 4 0"/></svg>
                    {%- when 'umbrella' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.2v1.8"/><path d="M3.8 13a8.2 8.2 0 0 1 16.4 0z"/><path d="M12 13v5.5a2 2 0 0 0 4 0"/></svg>
                    {%- when 'camera' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8.5h2.8L8 6.5h8l1.2 2H20a1 1 0 0 1 1 1v8.5a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5a1 1 0 0 1 1-1z"/><circle cx="12" cy="13" r="3.2"/></svg>
                    {%- when 'key' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="8.5" cy="8.5" r="3.8"/><path d="M11 11l8 8"/><path d="M16.5 16.5l1.8-1.8"/><path d="M19 19l1.6-1.6"/></svg>
                    {%- when 'carseat' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13a7 7 0 0 1 14 0v3a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z"/><path d="M8 6.2a6 6 0 0 1 8 0"/><path d="M9 13h6"/></svg>
                    {%- when 'suitcase' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="8" width="16" height="11" rx="2"/><path d="M9 8V6a1.5 1.5 0 0 1 1.5-1.5h3A1.5 1.5 0 0 1 15 6v2"/><path d="M4 13h16"/></svg>
                    {%- when 'pillow' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9c0-1.6 1-2.6 3-2.6h10c2 0 3 1 3 2.6v6c0 1.6-1 2.6-3 2.6H7c-2 0-3-1-3-2.6z"/><path d="M7 9c2.2 1 7.8 1 10 0"/><path d="M7 15c2.2-1 7.8-1 10 0"/></svg>
                    {%- when 'home' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11l8-6 8 6"/><path d="M6 10v9h12v-9"/><path d="M10 19v-5h4v5"/></svg>
                    {%- when 'rattle' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="5"/><circle cx="9" cy="9" r="1.4"/><path d="M12.6 12.6l2.9 2.9"/><path d="M15.5 15.5l1.6 1.6a1.6 1.6 0 1 1-2.3 2.3l-1.6-1.6"/></svg>
                    {%- when 'tricycle' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="16" r="3.4"/><circle cx="15.5" cy="17.5" r="2"/><circle cx="20" cy="17.5" r="2"/><path d="M6 16l4-8h4l3.5 9.5"/><path d="M10 8h4.5"/></svg>
                    {%- when 'discount' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13V5.5A1.5 1.5 0 0 1 5.5 4H13l7 7-7.5 7.5a1.5 1.5 0 0 1-2.1 0L4.4 14.1A1.5 1.5 0 0 1 4 13z"/><circle cx="8" cy="8" r="1.2"/><path d="M11 14.5l4-4"/><circle cx="11.4" cy="11" r=".8"/><circle cx="14.6" cy="14.2" r=".8"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8h12l-1 12H7z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>
                  {%- endcase -%}
                </span>
                <h2 class="home-hero_category-title">{{ link.title }}</h2>
                {% if link.links.size > 0 %}
                  <svg class="home-hero_category-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                {% endif %}
              </a>
            {% endunless %}
          {% endfor %}

          <!-- SUBCATEGORII -->
          <div class="home-hero_subcategories-wrapper" data-home-hero-subcategories-wrapper>
            <div class="home-hero_subcategories-inner">
              <h3 class="home-hero_subcategories-title" data-home-hero-subcategories-title>Category name</h3>
              <div class="home-hero_subcategories-list" data-subcategories>
                {% for link in linklists['main-menu'].links %}
                  {% if link.links.size > 0 %}
                    <div class="subcategory-group hidden" data-subcategory-group data-category="{{ link.title | escape }}">
                      {% for childlink in link.links %}
                        <a href="{{ childlink.url }}" class="home-hero_subcategories-item">{{ childlink.title }}</a>
                      {% endfor %}
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        </div>

        <!-- CARUSEL -->
        <div class="home-hero_right">
          <div class="home-hero_swiper" data-home-hero-carousel>
            <div class="home-hero_swiper-wrapper" data-home-hero-track>
              {% for block in section.blocks %}
                {% if block.type == 'slide' %}
                  {% assign image_loading = 'lazy' %}
                  {% if forloop.first %}
                    {% assign image_loading = 'eager' %}
                  {% endif %}
                  <div class="home-hero_slide" data-home-hero-slide {{ block.shopify_attributes }}>
                    {% if block.settings.link != blank %}
                      <a href="{{ block.settings.link }}" class="home-hero_slide-link">
                    {% endif %}
                    {% if block.settings.image != blank %}
                      {% assign image_alt = block.settings.image.alt | default: 'Banner promoțional' %}
                      <img src="{{ block.settings.image | image_url: width: 1400 }}"
                           srcset="{{ block.settings.image | image_url: width: 700 }} 700w, {{ block.settings.image | image_url: width: 1000 }} 1000w, {{ block.settings.image | image_url: width: 1400 }} 1400w, {{ block.settings.image | image_url: width: 1800 }} 1800w, {{ block.settings.image | image_url: width: 2200 }} 2200w"
                           sizes="(min-width: 990px) 888px, 100vw"
                           alt="{{ image_alt | escape }}"
                           class="home-hero_slide-image"
                           loading="{{ image_loading }}"
                           width="{{ block.settings.image.width }}"
                           height="{{ block.settings.image.height }}">
                    {% else %}
                      {{ 'lifestyle-1' | placeholder_svg_tag: 'home-hero_slide-placeholder' }}
                    {% endif %}
