{% comment %} SR-ADDED: Home Hero forced animations {% endcomment %}
<style>
  .home-hero-motion-ready .home-hero_category,
  .home-hero-motion-ready .home-hero_swiper,
  .home-hero-motion-ready .home-hero_pagination-dot {
    opacity: 0;
    transform: translateY(34px) scale(0.96);
    filter: blur(8px);
  }

  .home-hero-motion-ready .home-hero_category.hh-visible,
  .home-hero-motion-ready .home-hero_swiper.hh-visible,
  .home-hero-motion-ready .home-hero_pagination-dot.hh-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
    transition:
      opacity 850ms cubic-bezier(.22, 1, .36, 1),
      transform 850ms cubic-bezier(.22, 1, .36, 1),
      filter 850ms cubic-bezier(.22, 1, .36, 1);
    transition-delay: var(--hh-delay, 0ms);
  }

  .home-hero_category,
  .home-hero_subcategories-item,
  .home-hero_category-title,
  .home-hero_subcategories-title {
    transition:
      transform 260ms ease,
      letter-spacing 260ms ease,
      color 260ms ease,
      background-color 260ms ease,
      padding-left 260ms ease !important;
  }

  .home-hero_category:hover .home-hero_category-title,
  .home-hero_subcategories-item:hover,
  .home-hero_subcategories-title:hover {
    transform: translateX(4px);
    letter-spacing: 0.015em;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero-motion-ready .home-hero_category,
    .home-hero-motion-ready .home-hero_swiper,
    .home-hero-motion-ready .home-hero_pagination-dot {
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  /* SR-ADDED: Home Hero direct animation */
  (function () {
    function runHomeHeroMotion() {
      var section = document.querySelector('.section_home-hero.home-hero-page-fixed');

      if (!section) {
        console.log('Home Hero Motion: sectiunea nu a fost gasita');
        return;
      }

      var prefersReducedMotion = window.matchMedia &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var items = section.querySelectorAll(
        '.home-hero_category, .home-hero_swiper, .home-hero_pagination-dot'
      );

      console.log('Home Hero Motion: elemente gasite:', items.length);

      section.classList.add('home-hero-motion-ready');

      if (prefersReducedMotion) {
        items.forEach(function (item) {
          item.classList.add('hh-visible');
        });
        return;
      }

      items.forEach(function (item, index) {
        item.style.setProperty('--hh-delay', Math.min(index * 55, 850) + 'ms');

        window.setTimeout(function () {
          item.classList.add('hh-visible');
        }, 80);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', runHomeHeroMotion);
    } else {
      runHomeHeroMotion();
    }

    document.addEventListener('shopify:section:load', runHomeHeroMotion);
  })();
</script>