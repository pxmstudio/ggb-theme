  function setBeforeState(el, x, y, blur) {
    el.style.setProperty('opacity', '0', 'important');
    el.style.setProperty('transform', 'translate3d(' + x + 'px, ' + y + 'px, 0) scale(.985)', 'important');
    el.style.setProperty('filter', 'blur(' + blur + 'px)', 'important');
  }

  function clearAfterState(el) {
    el.style.removeProperty('opacity');
    el.style.removeProperty('transform');
    el.style.removeProperty('filter');
    el.style.setProperty('will-change', 'auto', 'important');
  }

  function animateElement(el, index, variant) {
    if (!el || el.dataset.srForceDone === 'true' || !isVisible(el)) return;

    el.dataset.srForceDone = 'true';

    var delay = Math.min(index * 55, 620);
    var x = 0;
    var y = 18;
    var blur = 8;

    if (variant === 'left') {
      x = -22;
      y = 0;
    }

    if (variant === 'right') {
      x = 22;
      y = 0;
    }

    if (variant === 'fade') {
      x = 0;
      y = 0;
      blur = 4;
    }

    if (!HAS_WAAPI) {
      el.style.setProperty('opacity', '1', 'important');
      return;
    }

    setBeforeState(el, x, y, blur);

    window.requestAnimationFrame(function () {
      var animation = el.animate([
        {
          opacity: 0,
          transform: 'translate3d(' + x + 'px, ' + y + 'px, 0) scale(.985)',
          filter: 'blur(' + blur + 'px)'
        },
        {
          opacity: 1,
          transform: 'translate3d(0, 0, 0) scale(1)',
          filter: 'blur(0)'
        }
      ], {
        duration: 760,
        delay: delay,
        easing: 'cubic-bezier(.22, 1, .36, 1)',
        fill: 'both'
      });

      animation.onfinish = function () {
        clearAfterState(el);
      };
    });
