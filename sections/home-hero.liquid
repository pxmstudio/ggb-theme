<link rel="stylesheet" href="{{ 'home-hero.css' | asset_url }}">
<link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css">
<script  defer src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>

<section class="section_home-hero">
  <div class="padding-global">
    <div class="container-large">
      <div class="padding-section-medium">
        <div class="home-hero_wrapper">
          <h1 style="display: none;">gogobady</h1>
          <div class="home-hero_left">
            {% for link in linklists.categories.links %}
              <div class="home-hero_category">
                <svg
                  class="home-hero_category-icon"
                  width="20"
                  height="21"
                  viewBox="0 0 20 21"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M4.16675 11.2333H6.66675M1.66675 7.9L3.33341 8.73334L4.39228 5.55673C4.61085 4.90105 4.72013 4.5732 4.92282 4.33082C5.10181 4.11678 5.33168 3.95111 5.59134 3.84898C5.88538 3.73334 6.23096 3.73334 6.92211 3.73334H13.0781C13.7692 3.73334 14.1148 3.73334 14.4088 3.84898C14.6685 3.95111 14.8983 4.11678 15.0773 4.33082C15.28 4.5732 15.3893 4.90105 15.6079 5.55673L16.6667 8.73334L18.3334 7.9M13.3334 11.2333H15.8334M5.66675 8.73334H14.3334C15.7335 8.73334 16.4336 8.73334 16.9684 9.00582C17.4388 9.2455 17.8212 9.62796 18.0609 10.0984C18.3334 10.6331 18.3334 11.3332 18.3334 12.7333V14.9833C18.3334 15.3705 18.3334 15.5642 18.3014 15.7252C18.1699 16.3863 17.653 16.9031 16.9919 17.0346C16.8309 17.0667 16.6373 17.0667 16.2501 17.0667H15.8334C14.9129 17.0667 14.1667 16.3205 14.1667 15.4C14.1667 15.1699 13.9802 14.9833 13.7501 14.9833H6.25008C6.01996 14.9833 5.83341 15.1699 5.83341 15.4C5.83341 16.3205 5.08722 17.0667 4.16675 17.0667H3.75008C3.36287 17.0667 3.16926 17.0667 3.00826 17.0346C2.34711 16.9031 1.83028 16.3863 1.69877 15.7252C1.66675 15.5642 1.66675 15.3705 1.66675 14.9833V12.7333C1.66675 11.3332 1.66675 10.6331 1.93923 10.0984C2.17892 9.62796 2.56137 9.2455 3.03177 9.00582C3.56655 8.73334 4.26662 8.73334 5.66675 8.73334Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>

                <h2 class="home-hero_category-title">{{ link.title }}</h2>
                <svg
                  class="home-hero_category-arrow"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M5 12H19M19 12L12 4.99998M19 12L12 19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {% endfor %}
           
            <div class="home-hero_subcategories-wrapper">
              <div class="home-hero_subcategories-inner">
              <h3 class="heading-style-5">Category name<h3>
                <div class="home-hero_subcategories-list">
                  <a href="your-link-here" class="home-hero_subcategories-item">
                    Subcategory Name
                  </a>
                  <a href="your-link-here" class="home-hero_subcategories-item">
                    Subcategory Name
                  </a>
                </div>
              </div>
            </div>
          </div>

          <div class="home-hero_right">
            <div class="home-hero_swiper swiper">
            <div class="home-hero_swiper-wrapper swiper-wrapper">
              <a href="your-link-1" class="home-hero_swiper-slide swiper-slide">
                <img src="{{ 'image1.jpg' | asset_url }}" alt="Slide 1">
              </a>
              <a href="your-link-2" class="home-hero_swiper-slide swiper-slide">
                <img src="{{ 'image2.jpg' | asset_url }}" alt="Slide 2">
              </a>
              <a href="your-link-3" class="home-hero_swiper-slide swiper-slide">
                <img src="{{ 'image3.jpg' | asset_url }}" alt="Slide 3">
              </a>
              
            </div></div>
          </div>
          
        </div>
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "mainEntity": {
      "@type": "ItemList",
      "name": "Hero Section",
      "itemListElement": [
        {% for link in linklists.categories.links %}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "name": "{{ link.title }}",
          "url": "{{ link.url }}",
          "itemListElement": [
            {
              "@type": "CategoryCode",
              "codeValue": "{{ link.title }}",
              "name": "Subcategory",
              "url": "your-subcategory-link-here"
            }
          ]
        }{% if forloop.last == false %},{% endif %}
        {% endfor %}
      ]
    },
    "hasPart": {
      "@type": "ImageGallery",
      "name": "Hero Carousel",
      "image": [
        {% for slide in hero_slides %}
        {
          "@type": "ImageObject",
          "url": "{{ slide.image | asset_url }}",
          "name": "Slide {{ forloop.index }}",
          "caption": "Hero slide description {{ forloop.index }}"
        }{% if forloop.last == false %},{% endif %}
        {% endfor %}
      ]
    }
  }
  </script>
  
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var swiper = new Swiper('.home-hero_swiper', {
      loop: true,
      slidesPerView: 1, 
      autoplay: {
        delay: 3000,
      },
      speed: 1500,
    });
  });
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const categoryElements = document.querySelectorAll(".home-hero_category");
    const parentElement = document.querySelector(".home-hero_left");
    const subcategoriesWrapper = document.querySelector(".home-hero_subcategories-wrapper");
    const headingElement = document.querySelector(".home-hero_subcategories-inner .heading-style-5");

    // Initially hide the subcategories wrapper
    if (subcategoriesWrapper) {
      gsap.set(subcategoriesWrapper, { opacity: 0, display: "none" });
    }

    categoryElements.forEach(category => {
      category.addEventListener("mouseenter", () => {
        // Remove 'is-active' class from all categories
        categoryElements.forEach(el => el.classList.remove("is-active"));
        // Add 'is-active' class to the hovered category
        category.classList.add("is-active");

        // Extract the text from the current category title
        const categoryTitle = category.querySelector(".home-hero_category-title")?.textContent || "";

        // Fade out the subcategories wrapper
        if (subcategoriesWrapper) {
          gsap.to(subcategoriesWrapper, {
            opacity: 0,
            duration: 0.15,
            onComplete: () => {
              // Update the heading text after opacity reaches 0
              if (headingElement) {
                headingElement.textContent = categoryTitle;
              }

              // Fade in the subcategories wrapper with the updated text
              gsap.set(subcategoriesWrapper, { display: "block" });
              gsap.to(subcategoriesWrapper, { opacity: 1, duration: 0.15 });
            }
          });
        }
      });
    });

    parentElement.addEventListener("mouseleave", () => {
      // Remove 'is-active' from all categories
      categoryElements.forEach(el => el.classList.remove("is-active"));

      // Hide the subcategories wrapper
      if (subcategoriesWrapper) {
        gsap.to(subcategoriesWrapper, { opacity: 0, duration: 0.15, onComplete: () => {
          gsap.set(subcategoriesWrapper, { display: "none" });
        }});
      }
    });
  });
</script>
