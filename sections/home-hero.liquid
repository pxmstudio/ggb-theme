{% comment %}
SR-ADDED
File sugerat: section-animated.liquid

Descriere:
- Adaugă scroll-triggered reveals, page/section load transitions și hover reveal pentru elementele de text.
- Implementarea folosește CSS + IntersectionObserver, fără dependențe externe.
- Conținutul rămâne vizibil fără JavaScript; animațiile se activează doar când clasa sr-js-enabled este adăugată automat pe <html>.
- Respectă prefers-reduced-motion: reduce prin afișare statică, fără tranziții.
- Funcția window.SectionRevealMotion.init() poate fi apelată manual după injectarea de conținut AJAX.
- Testare recomandată: resize viewport, scroll lent, navigare cu tastatură, DevTools > Rendering > Emulate CSS media feature prefers-reduced-motion.
{% endcomment %}
<link rel="stylesheet" href="{{ 'home-hero.css' | asset_url }}">
{% comment %} SR-ADDED: Scope pentru scanarea automată a textelor animate în această secțiune. {% endcomment %}
<section class="section_home-hero home-hero-page-fixed" data-home-hero-section="{{ section.id }}" data-sr-scope data-sr-container data-sr-stagger="65" >
<div class="global-padding">
<div class="container-large">
<div class="padding-section-medium">
<div class="home-hero_wrapper">
<h1 style="display: none;">gogobaby</h1>

<!-- MENIU CATEGORII -->
<div class="home-hero_left" data-home-hero-menu>
{% for link in linklists['main-menu'].links %}
{% unless forloop.first or forloop.last %}
{% assign title_downcase = link.title | downcase %}
{% assign category_emoji = '🛍️' %}
{% if title_downcase contains 'transport' %}
{% assign category_emoji = '🚚' %}
{% elsif title_downcase contains 'masa' or title_downcase contains 'masă' %}
{% assign category_emoji = '🍼' %}
{% elsif title_downcase contains 'camera' %}
{% assign category_emoji = '🛏️' %}
{% elsif title_downcase contains 'parinti' or title_downcase contains 'părinți' %}
{% assign category_emoji = '👨‍👩‍👧' %}
{% elsif title_downcase contains 'curat' or title_downcase contains 'sanatos' or title_downcase contains 'sănătos' %}
{% assign category_emoji = '🧼' %}
{% elsif title_downcase contains 'hainute' or title_downcase contains 'hăinuțe' or title_downcase contains 'incaltaminte' or title_downcase contains 'încălțăminte' %}
{% assign category_emoji = '👕' %}
{% elsif title_downcase contains 'exterior' %}
{% assign category_emoji = '🛝' %}
{% elsif title_downcase contains 'jucarii' or title_downcase contains 'jucării' or title_downcase contains 'jocuri' %}
{% assign category_emoji = '🧸' %}
{% elsif title_downcase contains 'cadouri' %}
{% assign category_emoji = '🎁' %}
{% elsif title_downcase contains 'plimbare' or title_downcase contains 'relaxare' %}
{% assign category_emoji = '🚲' %}
{% elsif title_downcase contains 'siguranta' or title_downcase contains 'siguranța' %}
{% assign category_emoji = '🛡️' %}
{% elsif title_downcase contains 'gradinita' or title_downcase contains 'grădinița' or title_downcase contains 'scoala' or title_downcase contains 'școala' %}
{% assign category_emoji = '🎒' %}
{% elsif title_downcase contains 'igiena' or title_downcase contains 'igienă' or title_downcase contains 'sănătate' %}
{% assign category_emoji = '🧴' %}
{% elsif title_downcase contains 'triciclete' or title_downcase contains 'biciclete' %}
{% assign category_emoji = '🚴' %}
{% elsif title_downcase contains 'vehicule' %}
{% assign category_emoji = '🛴' %}
{% elsif title_downcase contains 'resigilate' %}
{% assign category_emoji = '📦' %}
{% endif %}
<a href="{{ link.url }}" class="home-hero_category" data-home-hero-category data-category-name="{{ link.title | escape }}" data-has-subcategories="{% if link.links.size > 0 %}true{% else %}false{% endif %}" >
<span class="home-hero_category-icon" aria-hidden="true"> {{ category_emoji }} </span>
<h2 class="home-hero_category-title"> {{ link.title }} </h2>
{% if link.links.size > 0 %}
<svg class="home-hero_category-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" >
<path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
</svg>
{% endif %}
</a>
{% endunless %}
{% endfor %}

<!-- SUBCATEGORII -->
<div class="home-hero_subcategories-wrapper" data-home-hero-subcategories-wrapper >
<div class="home-hero_subcategories-inner">
<h3 class="home-hero_subcategories-title" data-home-hero-subcategories-title > Category name </h3>
<div class="home-hero_subcategories-list" data-subcategories >
{% for link in linklists['main-menu'].links %}
{% if link.links.size > 0 %}
<div class="subcategory-group hidden" data-subcategory-group data-category="{{ link.title | escape }}" >
{% for childlink in link.links %}
<a href="{{ childlink.url }}" class="home-hero_subcategories-item" > {{ childlink.title }} </a>
{% endfor %}
</div>
{% endif %}
{% endfor %}
</div>
</div>
</div>
</div>

<!-- CARUSEL -->
<div class="home-hero_right">
<div class="home-hero_swiper" data-home-hero-carousel >
<div class="home-hero_swiper-wrapper" data-home-hero-track >
{% for block in section.blocks %}
{% if block.type == 'slide' %}
{% assign image_loading = 'lazy' %}
{% if forloop.first %}
{% assign image_loading = 'eager' %}
{% endif %}
<div class="home-hero_slide" data-home-hero-slide {{ block.shopify_attributes }} >
{% if block.settings.link != blank %}
<a href="{{ block.settings.link }}" class="home-hero_slide-link" >
{% endif %}
{% if block.settings.image != blank %}
{% assign image_alt = block.settings.image.alt | default: 'Banner promoțional' %}
<img src="{{ block.settings.image | image_url: width: 1400 }}" srcset=" {{ block.settings.image | image_url: width: 700 }} 700w, {{ block.settings.image | image_url: width: 1000 }} 1000w, {{ block.settings.image | image_url: width: 1400 }} 1400w, {{ block.settings.image | image_url: width: 1800 }} 1800w, {{ block.settings.image | image_url: width: 2200 }} 2200w " sizes="(min-width: 990px) 888px, 100vw" alt="{{ image_alt | escape }}" class="home-hero_slide-image" loading="{{ image_loading }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" >
{% else %} {{ 'lifestyle-1' | placeholder_svg_tag: 'home-hero_slide-placeholder' }}
{% endif %}
{% if block.settings.link != blank %}
</a>
{% endif %}
</div>
{% endif %}
{% endfor %}
</div>
<div class="home-hero_swiper-pagination" data-home-hero-pagination aria-label="Navigare carusel" >
{% for block in section.blocks %}
{% if block.type == 'slide' %}
<button type="button" class="home-hero_pagination-dot{% if forloop.first %} is-active{% endif %}" data-home-hero-dot data-slide-index="{{ forloop.index0 }}" aria-label="Afișează imaginea {{ forloop.index }}" ></button>
{% endif %}
{% endfor %}
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
<style>

/* SR-ADDED START: Scroll reveal + hover reveal layer.
   Customizare rapidă:
   --sr-duration: durata animației;
   --sr-stagger: întârzierea dintre elemente;
   --sr-distance: distanța de plecare;
   --sr-ease: easing pentru mișcare naturală.
*/
:root {
  --sr-duration: 720ms;
  --sr-stagger: 65ms;
  --sr-distance: 18px;
  --sr-ease: cubic-bezier(0.22, 1, 0.36, 1);
  --sr-hover-duration: 260ms;
}

[data-sr-scope] {
  --sr-section-delay: 80ms;
}

html.sr-js-enabled [data-sr-scope][data-sr-ready="true"] .sr-item {
  opacity: 0;
  transform: translate3d(0, var(--sr-distance), 0);
  filter: blur(6px);
  clip-path: inset(0 0 12% 0);
  will-change: opacity, transform, filter, clip-path;
  transition:
    opacity var(--sr-duration) var(--sr-ease) calc(var(--sr-section-delay) + (var(--sr-order, 0) * var(--sr-stagger))),
    transform var(--sr-duration) var(--sr-ease) calc(var(--sr-section-delay) + (var(--sr-order, 0) * var(--sr-stagger))),
    filter var(--sr-duration) var(--sr-ease) calc(var(--sr-section-delay) + (var(--sr-order, 0) * var(--sr-stagger))),
    clip-path var(--sr-duration) var(--sr-ease) calc(var(--sr-section-delay) + (var(--sr-order, 0) * var(--sr-stagger)));
}

html.sr-js-enabled [data-sr-scope][data-sr-ready="true"] .sr-item.sr-from-left {
  transform: translate3d(calc(var(--sr-distance) * -1), 0, 0);
}

html.sr-js-enabled [data-sr-scope][data-sr-ready="true"] .sr-item.sr-from-right {
  transform: translate3d(var(--sr-distance), 0, 0);
}

html.sr-js-enabled [data-sr-scope][data-sr-ready="true"] .sr-item.sr-fade {
  transform: translate3d(0, 0, 0);
}

html.sr-js-enabled [data-sr-scope][data-sr-ready="true"] .sr-item.is-visible {
  opacity: 1;
  transform: translate3d(0, 0, 0);
  filter: blur(0);
  clip-path: inset(0 0 0 0);
}

html.sr-js-enabled [data-sr-scope] .sr-hover {
  background-image: linear-gradient(currentColor, currentColor);
  background-repeat: no-repeat;
  background-size: 0% 1px;
  background-position: 0 100%;
  text-decoration-thickness: from-font;
  text-underline-offset: 0.18em;
  transition:
    background-size var(--sr-hover-duration) var(--sr-ease),
    transform var(--sr-hover-duration) var(--sr-ease),
    opacity var(--sr-hover-duration) var(--sr-ease);
}

html.sr-js-enabled [data-sr-scope] .sr-hover:hover,
html.sr-js-enabled [data-sr-scope] a:hover .sr-hover,
html.sr-js-enabled [data-sr-scope] button:hover .sr-hover,
html.sr-js-enabled [data-sr-scope] .sr-hover:focus-visible {
  background-size: 100% 1px;
  transform: translate3d(0, -1px, 0);
}

html.sr-js-enabled [data-sr-scope] button.sr-hover,
html.sr-js-enabled [data-sr-scope] a.sr-hover {
  -webkit-tap-highlight-color: transparent;
}

html.sr-reduced-motion [data-sr-scope] .sr-item,
html.sr-reduced-motion [data-sr-scope] .sr-hover {
  opacity: 1 !important;
  transform: none !important;
  filter: none !important;
  clip-path: none !important;
  transition: none !important;
  animation: none !important;
  background-size: 0% 1px !important;
  will-change: auto !important;
}

@media (prefers-reduced-motion: reduce) {
  [data-sr-scope] .sr-item,
  [data-sr-scope] .sr-hover {
    opacity: 1 !important;
    transform: none !important;
    filter: none !important;
    clip-path: none !important;
    transition: none !important;
    animation: none !important;
    will-change: auto !important;
  }
}
/* SR-ADDED END */

