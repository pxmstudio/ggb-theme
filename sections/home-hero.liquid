    section.dataset.srForceInit = 'true';
    section.classList.add('sr-force-motion-active');

    var items = collectItems(section);

    animateGroup(items.menuItems, 'left');
    animateGroup(items.menuTitles, 'fade');
    animateGroup(items.menuIcons, 'fade');
    animateGroup(items.carousel, 'right');
    animateGroup(items.dots, 'fade');

    qsa(section, '[data-home-hero-category]').forEach(function (category) {
      category.addEventListener('mouseenter', function () {
        window.setTimeout(function () {
          qsa(section, '.home-hero_subcategories-wrapper.is-active .home-hero_subcategories-title, .home-hero_subcategories-wrapper.is-active .home-hero_subcategories-item').forEach(function (el) {
            delete el.dataset.srForceDone;
          });
          animateGroup(qsa(section, '.home-hero_subcategories-wrapper.is-active .home-hero_subcategories-title'), 'right');
          animateGroup(qsa(section, '.home-hero_subcategories-wrapper.is-active .home-hero_subcategories-item'), 'right');
        }, 40);
      }, { passive: true });
