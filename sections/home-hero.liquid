<section class="baby-hero-section">

  <style>
    .baby-hero-section {
      width: 100%;
      max-width: 1440px;
      margin: 0 auto;
      background: #ffffff;
      overflow: hidden;
      font-family: Arial, Helvetica, sans-serif;
    }

    .baby-hero-topbar {
      width: 100%;
      min-height: 34px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 0 18px;
      background: linear-gradient(90deg, #5b3ee7 0%, #b656e8 100%);
      box-sizing: border-box;
      color: #ffffff;
      font-size: 13px;
      font-weight: 600;
      line-height: 1;
    }

    .baby-hero-topbar a {
      color: #ffffff;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
    }

    .baby-hero-topbar-left,
    .baby-hero-topbar-right {
      display: flex;
      align-items: center;
      gap: 24px;
    }

    .baby-hero-sale-btn {
      background: #ffc65a;
      color: #ffffff !important;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
    }

    .baby-hero-layout {
      display: grid;
      grid-template-columns: 245px minmax(0, 1fr);
      width: 100%;
      min-height: 430px;
    }

    .baby-hero-category-menu {
      background: #ffffff;
      border-left: 1px solid #eeeeee;
      border-right: 1px solid #eeeeee;
      border-bottom: 1px solid #eeeeee;
      box-sizing: border-box;
      padding: 8px 0;
      display: flex;
      flex-direction: column;
      min-height: 430px;
    }

    .baby-hero-category-menu a {
      min-height: 33px;
      padding: 0 14px;
      color: #333333;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      line-height: 1.2;
      display: flex;
      align-items: center;
      gap: 7px;
      border-bottom: 1px solid rgba(0,0,0,0.04);
      box-sizing: border-box;
      transition: background 0.25s ease, color 0.25s ease, padding-left 0.25s ease;
    }

    .baby-hero-category-menu a:hover {
      background: #f4efff;
      color: #6a3de8;
      padding-left: 18px;
    }

    .baby-hero-carousel {
      position: relative;
      width: 100%;
      height: 430px;
      overflow: hidden;
      background: #f8e2b7;
    }

    .baby-hero-track {
      position: relative;
      width: 100%;
      height: 100%;
    }

    .baby-hero-slide {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.55s ease, visibility 0.55s ease;
    }

    .baby-hero-slide.is-active {
      opacity: 1;
      visibility: visible;
      z-index: 2;
    }

    .baby-hero-slide img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center;
    }

    .baby-hero-arrow {
      position: absolute;
      top: 50%;
      z-index: 10;
      transform: translateY(-50%);
      width: 42px;
      height: 42px;
      border: none;
      border-radius: 999px;
      background: rgba(255,255,255,0.88);
      color: #5b3ee7;
      font-size: 34px;
      line-height: 1;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px rgba(0,0,0,0.14);
      transition: transform 0.2s ease, background 0.2s ease;
    }

    .baby-hero-arrow:hover {
      background: #ffffff;
      transform: translateY(-50%) scale(1.05);
    }

    .baby-hero-prev {
      left: 14px;
    }

    .baby-hero-next {
      right: 14px;
    }

    .baby-hero-dots {
      position: absolute;
      left: 50%;
      bottom: 12px;
      z-index: 12;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
    }

    .baby-hero-dots button {
      width: 9px;
      height: 9px;
      border: none;
      border-radius: 999px;
      background: rgba(255,255,255,0.85);
      cursor: pointer;
      padding: 0;
      transition: background 0.25s ease, transform 0.25s ease;
    }

    .baby-hero-dots button.is-active {
      background: #f5a623;
      transform: scale(1.15);
    }

    @media (max-width: 1024px) {
      .baby-hero-topbar {
        padding: 8px 12px;
        overflow-x: auto;
        justify-content: flex-start;
      }

      .baby-hero-topbar-left,
      .baby-hero-topbar-right {
        gap: 16px;
        flex: 0 0 auto;
      }

      .baby-hero-layout {
        grid-template-columns: 1fr;
        min-height: unset;
      }

      .baby-hero-category-menu {
        min-height: unset;
        flex-direction: row;
        overflow-x: auto;
        white-space: nowrap;
        padding: 7px 8px;
        border-left: none;
        border-right: none;
      }

      .baby-hero-category-menu a {
        flex: 0 0 auto;
        min-height: 34px;
        border-bottom: none;
        border-radius: 999px;
        background: #f6f2ff;
        margin-right: 8px;
        padding: 0 14px;
        font-size: 12px;
      }

      .baby-hero-category-menu a:hover {
        padding-left: 14px;
      }

      .baby-hero-carousel {
        height: auto;
        aspect-ratio: 16 / 7;
      }
    }

    @media (max-width: 767px) {
      .baby-hero-section {
        border-radius: 0;
      }

      .baby-hero-topbar {
        font-size: 12px;
        min-height: 38px;
      }

      .baby-hero-sale-btn {
        padding: 5px 10px;
        font-size: 11px;
      }

      .baby-hero-carousel {
        aspect-ratio: 16 / 10;
      }

      .baby-hero-arrow {
        width: 34px;
        height: 34px;
        font-size: 28px;
      }

      .baby-hero-prev {
        left: 8px;
      }

      .baby-hero-next {
        right: 8px;
      }

      .baby-hero-dots {
        bottom: 9px;
      }

      .baby-hero-dots button {
        width: 8px;
        height: 8px;
      }
    }
  </style>

  <div class="baby-hero-topbar">
    <div class="baby-hero-topbar-left">
      <a href="#">☰ Produse</a>
      <a href="#">🛍 Noutăți</a>
      <a href="#">Idei cadouri</a>
    </div>

    <div class="baby-hero-topbar-right">
      <a class="baby-hero-sale-btn" href="#">Adventurous Days Sale</a>
      <a href="#">Blog</a>
      <a href="#">Contact</a>
    </div>
  </div>

  <div class="baby-hero-layout">

    <aside class="baby-hero-category-menu">
      <a href="#">✈ Articole Transport</a>
      <a href="#">🍼 Bebe la Masă</a>
      <a href="#">🛏 Camera Bebelușului</a>
      <a href="#">🚗 Articole Părinți</a>
      <a href="#">🧸 Joacă și Senzoriale</a>
      <a href="#">👶 Îmbrăcat Bebeluș</a>
      <a href="#">🌿 Joacă în Exterior</a>
      <a href="#">🎁 Jucării & Cadouri</a>
      <a href="#">🧘 Plimbare & Relaxare</a>
      <a href="#">⭐ Siguranță Interior</a>
      <a href="#">🎀 Cadouri și Stocuri</a>
      <a href="#">📦 Produse Resigilate</a>
    </aside>

    <div class="baby-hero-carousel">
      <div class="baby-hero-track">

        <div class="baby-hero-slide is-active">
          <img src="https://via.placeholder.com/1200x430/f8e2af/111111?text=TEHNOLOGIE+AVANSATA+PENTRU+INGRIJIREA+BEBELUSULUI" alt="Slide 1">
        </div>

        <div class="baby-hero-slide">
          <img src="https://via.placeholder.com/1200x430/f3d894/111111?text=PRODUSE+PREMIUM+PENTRU+BEBELUSI" alt="Slide 2">
        </div>

        <div class="baby-hero-slide">
          <img src="https://via.placeholder.com/1200x430/ffe1aa/111111?text=NOUTATI+SI+CADOURI+PENTRU+PARINTI" alt="Slide 3">
        </div>

        <div class="baby-hero-slide">
          <img src="https://via.placeholder.com/1200x430/f7d7a0/111111?text=SIGURANTA+CONFORT+SI+FUNCTIONALITATE" alt="Slide 4">
        </div>

      </div>

      <button class="baby-hero-arrow baby-hero-prev" type="button" aria-label="Slide anterior">‹</button>
      <button class="baby-hero-arrow baby-hero-next" type="button" aria-label="Slide următor">›</button>

      <div class="baby-hero-dots">
        <button class="is-active" type="button" aria-label="Slide 1"></button>
        <button type="button" aria-label="Slide 2"></button>
        <button type="button" aria-label="Slide 3"></button>
        <button type="button" aria-label="Slide 4"></button>
      </div>
    </div>

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const carousels = document.querySelectorAll(".baby-hero-carousel");

      carousels.forEach(function (carousel) {
        const slides = carousel.querySelectorAll(".baby-hero-slide");
        const dots = carousel.querySelectorAll(".baby-hero-dots button");
        const prevBtn = carousel.querySelector(".baby-hero-prev");
        const nextBtn = carousel.querySelector(".baby-hero-next");

        if (!slides.length) return;

        let current = 0;
        let timer = null;

        function goToSlide(index) {
          slides[current].classList.remove("is-active");
          if (dots[current]) dots[current].classList.remove("is-active");

          current = (index + slides.length) % slides.length;

          slides[current].classList.add("is-active");
          if (dots[current]) dots[current].classList.add("is-active");
        }

        function nextSlide() {
          goToSlide(current + 1);
        }

        function prevSlide() {
          goToSlide(current - 1);
        }

        function startAutoplay() {
          stopAutoplay();
          timer = setInterval(nextSlide, 4000);
        }

        function stopAutoplay() {
          if (timer) clearInterval(timer);
        }

        function resetAutoplay() {
          stopAutoplay();
          startAutoplay();
        }

        if (nextBtn) {
          nextBtn.addEventListener("click", function () {
            nextSlide();
            resetAutoplay();
          });
        }

        if (prevBtn) {
          prevBtn.addEventListener("click", function () {
            prevSlide();
            resetAutoplay();
          });
        }

        dots.forEach(function (dot, index) {
          dot.addEventListener("click", function () {
            goToSlide(index);
            resetAutoplay();
          });
        });

        carousel.addEventListener("mouseenter", stopAutoplay);
        carousel.addEventListener("mouseleave", startAutoplay);

        startAutoplay();
      });
    });
  </script>

</section>