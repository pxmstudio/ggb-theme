<div
  class="
    h-20 lg:h-20
    w-full z-100 mb-[-2rem]
  "
>
  <header class="header-black-friday fixed top-0 left-1/2 transform -translate-x-1/2 bg-bg-orange w-full m-0 mx-auto z-50 ">
    <div class="global-padding">
      <div class="container-large">
        <div class="header-black-friday_wrapper w-full flex justify-between items-center gap-8">
          {% if template.name == 'index' %}
            <h1 class="relative z-100">
              <span class="sr-only">GoGoBaby</span>
          {% endif %}
          <a
            style="z-index: 100;"
            href="/"
            class="global-transition flex justify-center bg-brand-turquoise border-none rounded-full px-3 lg:px-6 py-1.5 lg:py-3 relative z-100 h-10 lg:h-16 w-auto"
          >
            {% render 'icon-logo' %}
          </a>
          {% if template.name == 'index' %}
            </h1>
          {% endif %}
          <div data-countdown="timer" class=" flex items-center  gap-2 ">
            <div class="flex items-center  gap-2" aria-label="Black Friday countdown timer">
              <div
                class="bg-bg-primary rounded-lg p-2 flex lg:gap-2 gap-1"
                data-countdown-box
                data-countdown-part="days"
                aria-label="Days remaining"
              >
                <div class="text-center w-[3ch]" data-countdown-value>00</div>
                <div class="font-medium">zile</div>
              </div>
              <div
                class="bg-bg-primary rounded-lg p-2 flex lg:gap-2 gap-1 poppins"
                data-countdown-box
                data-countdown-part="hours"
                aria-label="Hours remaining"
              >
                <div class="text-center w-[2ch]" data-countdown-value>00</div>
                <div class="font-medium  ">ore</div>
              </div>
              <div
                class="bg-bg-primary rounded-lg p-2 flex lg:gap-2 gap-1"
                data-countdown-box
                data-countdown-part="minutes"
                aria-label="Minutes remaining"
              >
                <div class="text-center w-[2ch]" data-countdown-value>00</div>
                <div class="font-medium  ">min</div>
              </div>
              <div
                class="bg-bg-primary rounded-lg p-2 flex lg:gap-2 gap-1 "
                data-countdown-box
                data-countdown-part="seconds"
                aria-label="Seconds remaining"
              >
                <div class=" text-center w-[3ch]" data-countdown-value>00</div>
                <div class="font-medium  ">sec</div>
              </div>
            </div>
            <p class="lg:text-xl text-sm block text-white font-semibold">până la finalul promoției</p>
          </div>
          <div class="hidden lg:block relative" pxm-nav="menu">
            <nav class="flex lg:flex-row flex-col pt-52 px-28 lg:pt-0 lg:px-0 lg:justify-end items-center gap-8 lg:gap-6 fixed lg:static top-0 left-0 right-0 bottom-0 z-40 h-screen lg:h-auto bg-bg-primary w-full lg:opacity-100">
              <div class="flex items-center gap-2 lg:justify-end">
                <!-- Search and Category Dropdown Form -->

                <!-- Account Links -->
                <div class="flex items-center gap-2 lg:gap-3 bg-bg-alternate">
                  {% render 'button-bf', type: 'link', hierarchy: 'primary', href: '/', text: 'Înapoi la website' %}
                  <div class="hidden lg:block">
                    {% render 'nav-acc-btn', path: '/cart', icon: 'cart' %}
                  </div>
                  {% comment %} {% render 'nav-acc-btn', path: '/pages/wishlist', icon: 'heart' %} {% endcomment %}
                </div>
              </div>
            </nav>
            {% render 'mobile-categories' %}
          </div>

          <!-- Mobile Buttons -->
          <div class="flex items-center gap-4 lg:hidden">
            <div class="z-50">
              {% render 'nav-acc-btn', path: '/cart', icon: 'cart' %}
            </div>
            {% comment %}
              <button
                class="lg:hidden relative w-10 h-10 py-3 px-2  flex-col items-center justify-center gap-1 bg-bg-secondary rounded-full z-50"
                pxm-nav="mobile-btn"
              >
                <div class="w-full h-[2px] rounded-2xl bg-neutral-darker" pxm-nav="mobile-btn-line"></div>
                <div class="w-full h-[2px] rounded-2xl bg-neutral-darker" pxm-nav="mobile-btn-line"></div>
                <div class="w-full h-[2px] rounded-2xl bg-neutral-darker" pxm-nav="mobile-btn-line"></div>
              </button>
            {% endcomment %}
          </div>
        </div>
      </div>
    </div>
    <img
      src="https://cdn.shopify.com/s/files/1/0431/6663/0052/files/shape.svg?v=1761899979"
      alt=""
      class="w-full h-8 object-cover object-left absolute bottom-[-2rem] left-0 "
      width="1440"
      height="32"
      style="object-position: left;"
    >
  </header>
</div>

<style>
  .header-black-friday_wrapper {
    padding-top: 1.5rem;
  }
  /* Ensure digits have equal width to avoid jitter */
  [data-countdown-value] {
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
    font-size: 1.5rem;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    width: 2ch;
  }
  @media (max-width: 1024px) {
    [data-countdown-value] {
      font-size: 1.25rem;
      width: 2.2ch;
    }

    [data-countdown] {
      font-size: 1rem;
    }
  }
  @media (max-width: 640px) {
    [data-countdown-value] {
      font-size: 1.125rem;
      width: 2ch;
    }
    [data-countdown='timer'] {
      position: fixed;
      top: calc(100vh - 5rem);
      bottom: auto;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      z-index: 1000;
      font-size: 0.75rem;
      padding: 0 0.5rem;
      background: #ea8050;
      padding: 0.5rem 0;
      height: 5rem;
      flex-direction: column;
    }
    [data-countdown-box] {
      padding: 0.25rem;
    }
  }
</style>
