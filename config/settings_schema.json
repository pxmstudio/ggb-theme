[
  {
    "name": "theme_info",
    "theme_name": "GoGoBaby",
    "theme_version": "0.0.1",
    "theme_author": "PixelMakers",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:settings_schema.logo.settings.favicon.label",
        "info": "t:settings_schema.logo.settings.favicon.info"
      }
    ]
  },
  {
    "name": "whatsapp",
    "settings": [
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "WhatsApp Number",
        "default": "+40727565056"
      }
    ]
  },
  {
    "name": "Black Friday",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_black_friday",
        "label": "Enable Black Friday mode",
        "default": false
      },
      {
        "type": "text",
        "id": "black_friday_start",
        "label": "Start datetime – Black Friday (ISO 8601)",
        "info": "Example: 2025-11-07T23:59:59+02:00"
      },
      {
        "type": "text",
        "id": "black_friday_end",
        "label": "End datetime – Black Friday (ISO 8601)",
        "info": "Example: 2025-11-08T23:59:59+02:00"
      },
      {
        "type": "text",
        "id": "black_week_start",
        "label": "Start datetime – Black Week (ISO 8601)",
        "info": "Example: 2025-11-29T23:59:59+02:00"
      },
      {
        "type": "text",
        "id": "black_week_end",
        "label": "End datetime – Black Week (ISO 8601)",
        "info": "Example: 2025-12-06T23:59:59+02:00"
      },
      {
        "type": "text",
        "id": "luna_cadourilor_start",
        "label": "Start datetime – Luna cadourilor (ISO 8601)",
        "info": "Example: 2025-11-29T23:59:59+02:00"
      },
      {
        "type": "text",
        "id": "luna_cadourilor_end",
        "label": "End datetime – Luna cadourilor (ISO 8601)",
        "info": "Example: 2025-12-06T23:59:59+02:00"
      },
      {
        "type": "url",
        "id": "black_friday_link",
        "label": "Black Friday link"
      },
       {
        "type": "text",
        "id": "promotii_start",
        "label": "Start datetime – Luna cadourilor (ISO 8601)",
        "info": "Example: 2025-11-29T23:59:59+02:00"
      },
      {
        "type": "text",
        "id": "promotii_end",
        "label": "End datetime – Luna cadourilor (ISO 8601)",
        "info": "Example: 2025-12-06T23:59:59+02:00"
      },
      {
        "type": "url",
        "id": "promotii_link",
        "label": "Black Friday link"
      },
      {
        "type": "url",
        "id": "black_week_link",
        "label": "Black Week link"
      },
      {
        "type": "url",
        "id": "luna_cadourilor_link",
        "label": "Luna Cadourilor link"
      }
    ]
  }
]
